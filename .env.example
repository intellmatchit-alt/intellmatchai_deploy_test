# ============================================
# P2P Relationship Intelligence App
# Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# Application
# ============================================
NODE_ENV=development
APP_NAME="P2P Network"
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ============================================
# MySQL Database
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=p2p_db
MYSQL_USER=p2p_user
MYSQL_PASSWORD=p2p_password
MYSQL_ROOT_PASSWORD=rootpassword

# Prisma Database URL
DATABASE_URL="mysql://p2p_user:p2p_password@localhost:3306/p2p_db"

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL="redis://localhost:6379"

# ============================================
# Neo4j Graph Database
# ============================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ============================================
# JWT Authentication
# ============================================
# Generate with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# S3 / MinIO Storage
# ============================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=p2p-uploads
S3_REGION=us-east-1

# MinIO Console
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================
# AI Services (Optional - Set up when ready)
# ============================================

# Azure Document Intelligence (OCR)
AZURE_DOCUMENT_ENDPOINT=
AZURE_DOCUMENT_KEY=

# People Data Labs (Enrichment)
PDL_API_KEY=

# Recombee (Recommendations)
RECOMBEE_DATABASE_ID=
RECOMBEE_SECRET_TOKEN=

# Cohere (Reranking)
COHERE_API_KEY=

# OpenAI (Explanations)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ============================================
# Email (for password reset, notifications)
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="P2P Network <noreply@example.com>"

# ============================================
# Frontend
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_NAME="P2P Network"
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,ar

# ============================================
# Security
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=dev

# ============================================
# Feature Flags (Enable/Disable features)
# ============================================
FEATURE_AZURE_OCR=false
FEATURE_PDL_ENRICHMENT=false
FEATURE_RECOMBEE=false
FEATURE_COHERE_RERANK=false
FEATURE_OPENAI_EXPLANATIONS=false
