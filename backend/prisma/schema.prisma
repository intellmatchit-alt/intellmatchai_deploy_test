  @@index([userId])
  @@index([userId, mode])
  @@index([status])
  @@index([organizationId, isTeamShared])
  @@map("deal_requests")
}

/// Deal Match Result model
/// Stores computed matches for a deal request
model DealMatchResult {
  id            String            @id @default(uuid())
  dealRequestId String            @map("deal_request_id")
  contactId     String            @map("contact_id")
  score         Int               @db.SmallInt
  category      DealMatchCategory
  reasonsJson   Json              @map("reasons_json")
  breakdownJson Json              @map("breakdown_json")
  openerMessage String?           @map("opener_message") @db.Text
  openerEdited  String?           @map("opener_edited") @db.Text
  // v4 matching engine fields
  surfacedStatus  String?           @map("surfaced_status") @db.VarChar(20)
  hardFilterStatus String?          @map("hard_filter_status") @db.VarChar(20)
  hardFilterReason String?          @map("hard_filter_reason") @db.VarChar(100)
  scoreBreakdownV4 Json?            @map("score_breakdown_v4")
  explanationV4    Json?            @map("explanation_v4")
  confidence       Float?
  rank             Int?
  status        DealMatchStatus   @default(NEW)
  savedAt       DateTime?         @map("saved_at")
  ignoredAt     DateTime?         @map("ignored_at")
