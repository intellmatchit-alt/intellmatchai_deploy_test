  assignees     TaskAssignee[]

  @@index([contactId])
  @@index([userId])
  @@index([dueDate])
  @@index([reminderAt])
  @@index([status])
  @@index([priority])
  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([userId, reminderAt])
  @@index([category])
  @@index([recurrenceId])
  @@index([assignedToId])
  @@fulltext([title, description])
  @@map("contact_tasks")
}

model TaskAssignee {
  id        String      @id @default(uuid())
  taskId    String      @map("task_id")
  contactId String      @map("contact_id")
  createdAt DateTime    @default(now()) @map("created_at")
  task      ContactTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  contact   Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([taskId, contactId])
  @@index([taskId])
  @@index([contactId])
  @@map("task_assignees")
}

/// User's opportunity intents (multiple per user supported)
/// Enables Job Opportunities feature: Intent → Match → Action
model OpportunityIntent {
  id            String                    @id @default(uuid())
  userId        String                    @map("user_id")
  title         String                    @default("Untitled Opportunity") @db.VarChar(200)
  intentType    OpportunityIntentType     @map("intent_type")
  roleArea      String?                   @map("role_area") @db.VarChar(255)
  seniority     SeniorityLevel?
  locationPref  String?                   @map("location_pref") @db.VarChar(255)
  remoteOk      Boolean                   @default(true) @map("remote_ok")
  minExperienceYears Int?                  @map("min_experience_years")
  notes         String?                   @db.Text
  workMode              String?           @map("work_mode") @db.VarChar(50)
  employmentType        String?           @map("employment_type") @db.VarChar(255)
  urgencyOrAvailability String?           @map("urgency_or_availability") @db.VarChar(50)
  visibility      OpportunityVisibility     @default(PRIVATE)
  isActive        Boolean                   @default(true) @map("is_active")
  lastMatchedAt   DateTime?                 @map("last_matched_at")
  organizationId  String?                   @map("organization_id")
  organization    Organization?             @relation(fields: [organizationId], references: [id])
  // Advanced / AI-enriched fields
  languages             Json?               @map("languages")
  certifications        Json?               @map("certifications")
  educationLevels       Json?               @map("education_levels")
  industries            Json?               @map("industries")
  salaryMin             Int?                @map("salary_min")
  salaryMax             Int?                @map("salary_max")
  salaryCurrency        String?             @map("salary_currency") @db.VarChar(3)
  noticePeriod          String?             @map("notice_period") @db.VarChar(100)
  relevantExperience    String?             @map("relevant_experience") @db.Text
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")
  sectorPrefs           OpportunityIntentSector[]
  skillPrefs            OpportunityIntentSkill[]
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  collaborationRequests CollaborationRequest[]
  matches               OpportunityMatch[]
  opportunityMembers    OpportunityMember[]

  @@index([userId])
  @@index([intentType])
  @@index([isActive])
  @@index([visibility])
  @@index([organizationId])
  @@index([createdAt(sort: Desc)])
  @@map("opportunity_intents")
}

/// Opportunity Intent-Sector preference relationship
model OpportunityIntentSector {
  id        String            @id @default(uuid())
  intentId  String            @map("intent_id")
  sectorId  String            @map("sector_id")
  createdAt DateTime          @default(now()) @map("created_at")
  intent    OpportunityIntent @relation(fields: [intentId], references: [id], onDelete: Cascade)
  sector    Sector            @relation(fields: [sectorId], references: [id])

  @@unique([intentId, sectorId])
  @@index([intentId])
  @@index([sectorId])
  @@map("opportunity_intent_sectors")
}

/// Opportunity Intent-Skill preference relationship
model OpportunityIntentSkill {
  id         String            @id @default(uuid())
  intentId   String            @map("intent_id")
  skillId    String            @map("skill_id")
  isRequired Boolean           @default(false) @map("is_required")
  createdAt  DateTime          @default(now()) @map("created_at")
  intent     OpportunityIntent @relation(fields: [intentId], references: [id], onDelete: Cascade)
  skill      Skill             @relation(fields: [skillId], references: [id])

  @@unique([intentId, skillId])
  @@index([intentId])
  @@index([skillId])
  @@index([isRequired])
  @@map("opportunity_intent_skills")
}

/// Opportunity match result (matched users or contacts)
model OpportunityMatch {
  id               String                 @id @default(uuid())
  intentId         String                 @map("intent_id")
  matchedUserId    String?                @map("matched_user_id")
  matchedContactId String?                @map("matched_contact_id")
  matchScore       Float                  @map("match_score")
  matchType        String                 @map("match_type")

  // v2: Enhanced classification
  matchLevel       MatchLevel?            @map("match_level")
  confidence       ConfidenceLevel?
  confidenceScore  Int?                   @map("confidence_score")
  hardFilterStatus HardFilterStatus?      @map("hard_filter_status")
  levelCappedReason String?               @map("level_capped_reason") @db.VarChar(500)
  isSparseProfile  Boolean                @default(false) @map("is_sparse_profile")

  // v2: Detailed breakdown (JSON)
  scoreBreakdown   Json?                  @map("score_breakdown")

  // v3: Enhanced matching fields
  deterministicScore Float?               @map("deterministic_score")
  aiScore            Float?               @map("ai_score")
  finalScore         Float?               @map("final_score")
  hardFilterReason   String?              @map("hard_filter_reason") @db.VarChar(100)
  explanationV3      Json?                @map("explanation_v3")
  rank               Int?

  // Insights
  reasons          Json
  risks            Json?
  missingSkills    Json?                  @map("missing_skills")

  // Actionable outputs
  suggestedAction  String?                @map("suggested_action")
  suggestedMessage       String?                @map("suggested_message") @db.Text
  suggestedMessageEdited String?                @map("suggested_message_edited") @db.Text
  nextSteps              Json?                  @map("next_steps")

  // Shared attributes
  sharedSectors    Json                   @map("shared_sectors")
  sharedSkills     Json                   @map("shared_skills")
  intentAlignment  String?                @map("intent_alignment")
  explanation      String?                @db.Text

  // AI validation
  aiValidated      Boolean                @default(false) @map("ai_validated")
  aiNotes          String?                @map("ai_notes") @db.Text

  // User actions
  status           OpportunityMatchStatus @default(PENDING)
  notes            String?                @db.Text
  viewedAt         DateTime?              @map("viewed_at")
  contactedAt      DateTime?              @map("contacted_at")
  archivedAt       DateTime?              @map("archived_at")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  intent           OpportunityIntent      @relation(fields: [intentId], references: [id], onDelete: Cascade)
  matchedUser      User?                  @relation("OpportunityMatchedUser", fields: [matchedUserId], references: [id])
  matchedContact   Contact?               @relation("OpportunityMatchedContact", fields: [matchedContactId], references: [id])

  @@unique([intentId, matchedUserId])
  @@unique([intentId, matchedContactId])
  @@index([intentId])
  @@index([matchedUserId])
  @@index([matchedContactId])
  @@index([matchScore(sort: Desc)])
  @@index([intentId, matchLevel])
  @@index([intentId, status])
  @@index([status])
  @@map("opportunity_matches")
}

/// Meeting model for calendar integration
model Meeting {
  id               String         @id @default(uuid())
  title            String         @db.VarChar(255)
  description      String?        @db.Text
  startTime        DateTime       @map("start_time")
  endTime          DateTime       @map("end_time")
  location         String?        @db.VarChar(500)
  videoLink        String?        @map("video_link") @db.VarChar(500)
  videoProvider    VideoProvider? @map("video_provider")
  createdById      String         @map("created_by_id")
  contactId        String?        @map("contact_id")
  taskId           String?        @unique @map("task_id")
  externalEventId  String?        @map("external_event_id") @db.VarChar(255)
  externalProvider String?        @map("external_provider") @db.VarChar(50)
  isAllDay         Boolean        @default(false) @map("is_all_day")
  reminderMinutes  Int?           @map("reminder_minutes")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  createdBy        User           @relation(fields: [createdById], references: [id])
  contact          Contact?       @relation("MeetingContact", fields: [contactId], references: [id])
  task             ContactTask?   @relation(fields: [taskId], references: [id])
  attendees        MeetingAttendee[]

  @@index([createdById])
  @@index([contactId])
  @@index([startTime])
  @@index([endTime])
  @@map("meetings")
}

/// Meeting attendee
model MeetingAttendee {
  id        String         @id @default(uuid())
  meetingId String         @map("meeting_id")
  email     String         @db.VarChar(255)
  name      String?        @db.VarChar(255)
  status    AttendeeStatus @default(PENDING)
  userId    String?        @map("user_id")
  contactId String?        @map("contact_id")
  createdAt DateTime       @default(now()) @map("created_at")
  meeting   Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User?          @relation("MeetingAttendeeUser", fields: [userId], references: [id])
  contact   Contact?       @relation("MeetingAttendeeContact", fields: [contactId], references: [id])

  @@unique([meetingId, email])
  @@index([meetingId])
  @@map("meeting_attendees")
}

/// Contact search request log
/// Stores search queries with hashed PII for privacy
model ContactSearchRequest {
  id               String          @id @default(uuid())
  userId           String          @map("user_id")
  queryHash        String          @map("query_hash") @db.VarChar(64)
  inputType        SearchInputType @map("input_type")
  intent           SearchIntent
  intentNote       String?         @map("intent_note") @db.VarChar(500)
  imageUploadId    String?         @map("image_upload_id")
  imageMode        String?         @map("image_mode") @db.VarChar(20)
  consentFaceMatch Boolean         @default(false) @map("consent_face_match")
  status           SearchStatus
  processingTimeMs Int?            @map("processing_time_ms")
  ocrJobId         String?         @map("ocr_job_id")
  enrichJobId      String?         @map("enrich_job_id")
  expiresAt        DateTime        @map("expires_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@index([userId])
  @@index([queryHash])
  @@index([userId, queryHash])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("contact_search_requests")
}

/// Search result candidate
/// Stores each matched candidate with score and reasons
model ContactSearchResult {
  id            String        @id @default(uuid())
  requestId     String        @map("request_id")
  candidateType CandidateType @map("candidate_type")
  candidateId   String        @map("candidate_id")
  score         Int           @db.SmallInt
  confidence    Decimal       @db.Decimal(3, 2)
  reasons       Json
  snapshot      Json
  rank          Int           @db.SmallInt
  createdAt     DateTime      @default(now()) @map("created_at")

  @@unique([requestId, candidateType, candidateId])
  @@index([requestId])
  @@index([candidateType, candidateId])
  @@index([score(sort: Desc)])
  @@map("contact_search_results")
}

/// User feedback on search results
/// Used to improve future ranking
model ContactSearchFeedback {
  id                   String         @id @default(uuid())
  requestId            String         @unique @map("request_id")
  confirmedCandidateId String?        @map("confirmed_candidate_id")
  confirmedType        CandidateType? @map("confirmed_type")
  rejectedCandidates   Json?          @map("rejected_candidates")
  notes                String?        @db.Text
  createdAt            DateTime       @default(now()) @map("created_at")

  @@index([requestId])
  @@index([confirmedCandidateId])
  @@map("contact_search_feedback")
}

/// Historical search pattern for ranking boost
/// Aggregated from confirmed feedback per user
model SearchPatternBoost {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  patternType  String   @map("pattern_type") @db.VarChar(50)
  patternValue String   @map("pattern_value") @db.VarChar(255)
  boostScore   Int      @default(0) @map("boost_score")
  confirmCount Int      @default(0) @map("confirm_count")
  lastUsedAt   DateTime @map("last_used_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([userId, patternType, patternValue])
  @@index([userId])
  @@index([patternType])
  @@index([boostScore(sort: Desc)])
  @@map("search_pattern_boosts")
}

/// Match feedback record
/// Used to improve future match scoring
model MatchFeedback {
  id                   String              @id @default(uuid())
  userId               String              @map("user_id")
  contactId            String              @map("contact_id")
  matchType            String              @default("contact") @map("match_type")
  action               MatchFeedbackAction
  matchScoreAtFeedback Int?                @map("match_score_at_feedback")
  rating               Int?                @db.TinyInt
  feedbackNote         String?             @map("feedback_note") @db.Text
  feedbackSource       String?             @map("feedback_source") @db.VarChar(50)
  createdAt            DateTime            @default(now()) @map("created_at")

  @@index([userId, contactId])
  @@index([userId, action])
  @@index([userId, createdAt(sort: Desc)])
  @@index([contactId])
  @@index([action])
  @@index([matchType])
  @@map("match_feedback")
}

/// Aggregated feedback stats per user-contact pair
/// Pre-computed for fast lookup during matching
model MatchFeedbackStats {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  contactId      String    @map("contact_id")
  acceptCount    Int       @default(0) @map("accept_count")
  rejectCount    Int       @default(0) @map("reject_count")
  saveCount      Int       @default(0) @map("save_count")
  connectCount   Int       @default(0) @map("connect_count")
  messageCount   Int       @default(0) @map("message_count")
  hideCount      Int       @default(0) @map("hide_count")
  feedbackScore  Int       @default(0) @map("feedback_score")
  avgRating      Decimal?  @map("avg_rating") @db.Decimal(2, 1)
  ratingCount    Int       @default(0) @map("rating_count")
  lastFeedbackAt DateTime? @map("last_feedback_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([userId, contactId])
  @@index([userId, feedbackScore(sort: Desc)])
  @@index([feedbackScore(sort: Desc)])
  @@index([lastFeedbackAt])
  @@map("match_feedback_stats")
}

/// Main pitch deck record
/// Stores uploaded pitch files and processing state
model Pitch {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  fileKey        String?       @map("file_key") @db.VarChar(500)
  fileName       String?       @map("file_name") @db.VarChar(255)
  fileType       PitchFileType @default(PDF) @map("file_type")
  fileSize       Int?          @map("file_size")
  language       String        @default("en") @db.VarChar(10)
  status         PitchStatus   @default(PENDING)
  title          String?       @db.VarChar(255)
  companyName    String?       @map("company_name") @db.VarChar(255)
  summary         String?           @db.Text
  detailedDesc    String?           @map("detailed_desc") @db.Text
  category        String?           @db.VarChar(100)
  stage           ProjectStage      @default(IDEA)
  investmentRange String?           @map("investment_range") @db.VarChar(255)
  timeline        String?           @db.Text
  lookingFor      Json?             @map("looking_for")
  keywords        Json?
  visibility      ProjectVisibility @default(PUBLIC)
  problemStatement String?      @map("problem_statement") @db.Text
  whatYouNeed      String?      @map("what_you_need") @db.Text
  metadata         Json?
  // v8 matching fields
  supportNeededTags Json?      @map("support_needed_tags")
  needEmbedding     Json?      @map("need_embedding")
  rawText        String?       @map("raw_text") @db.LongText
  organizationId String?       @map("organization_id")
  isActive       Boolean       @default(true) @map("is_active")
  isTeamShared   Boolean       @default(false) @map("is_team_shared")
  uploadedAt     DateTime      @default(now()) @map("uploaded_at")
  processedAt    DateTime?     @map("processed_at")
  expiresAt      DateTime?     @map("expires_at")
  lastError      String?       @map("last_error") @db.Text
  deletedAt      DateTime?     @map("deleted_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections       PitchSection[]
  pitchSectors   PitchSector[]
  pitchSkills    PitchSkill[]
  needs          PitchNeed[]
  pitchJobs      PitchJob[]
  pitchMembers   PitchMember[]
  collaborationRequests CollaborationRequest[]

  @@index([userId])
  @@index([status])
  @@index([uploadedAt(sort: Desc)])
  @@index([userId, status])
  @@index([expiresAt])
  @@index([organizationId, isTeamShared])
  @@map("pitches")
}

/// Pitch-Sector relationship
model PitchSector {
  id        String   @id @default(uuid())
  pitchId   String   @map("pitch_id")
  sectorId  String   @map("sector_id")
  createdAt DateTime @default(now()) @map("created_at")
  pitch     Pitch    @relation(fields: [pitchId], references: [id], onDelete: Cascade)
  sector    Sector   @relation(fields: [sectorId], references: [id])

  @@unique([pitchId, sectorId])
  @@index([pitchId])
  @@index([sectorId])
  @@map("pitch_sectors")
}

/// Pitch-Skill relationship
model PitchSkill {
  id         String          @id @default(uuid())
  pitchId    String          @map("pitch_id")
  skillId    String          @map("skill_id")
  importance SkillImportance @default(REQUIRED)
  createdAt  DateTime        @default(now()) @map("created_at")
  pitch      Pitch           @relation(fields: [pitchId], references: [id], onDelete: Cascade)
  skill      Skill           @relation(fields: [skillId], references: [id])

  @@unique([pitchId, skillId])
  @@index([pitchId])
  @@index([skillId])
  @@map("pitch_skills")
}

/// Classified sections of the pitch deck
/// Each section corresponds to a slide group or content block
model PitchSection {
  id              String           @id @default(uuid())
  pitchId         String           @map("pitch_id")
  type            PitchSectionType
  order           Int              @db.SmallInt
  title           String           @db.VarChar(255)
  content         String           @db.Text
  rawContent      String?          @map("raw_content") @db.Text
  confidence      Float            @default(0)
  embedding       Json?
  embeddingModel  String?          @default("text-embedding-ada-002") @map("embedding_model") @db.VarChar(100)
  inferredSectors Json?            @map("inferred_sectors")
  inferredSkills  Json?            @map("inferred_skills")
  keywords        Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  pitch           Pitch            @relation(fields: [pitchId], references: [id], onDelete: Cascade)
  pitchMatches    PitchMatch[]

  @@index([pitchId])
  @@index([type])
  @@index([pitchId, order])
  @@map("pitch_sections")
}

/// Extracted needs from the pitch
/// Structured representation of what the startup needs
model PitchNeed {
  id                String            @id @default(uuid())
  pitchId           String            @map("pitch_id")
  key               PitchNeedKey
  label             String            @db.VarChar(255)
  description       String?           @db.Text
  confidence        Float             @default(0)
  sourceSectionType PitchSectionType? @map("source_section_type")
  amount            String?           @db.VarChar(100)
  timeline          String?           @db.VarChar(100)
  priority          Int               @default(1) @db.SmallInt
  createdAt         DateTime          @default(now()) @map("created_at")
  pitch             Pitch             @relation(fields: [pitchId], references: [id], onDelete: Cascade)

  @@index([pitchId])
  @@index([key])
  @@index([pitchId, key])
  @@map("pitch_needs")
}

/// Match between a pitch section and a contact
/// Core output of the PNME system
model PitchMatch {
  id                String              @id @default(uuid())
  pitchSectionId    String              @map("pitch_section_id")
  contactId         String              @map("contact_id")
  score             Int                 @default(0) @db.SmallInt
  relevanceScore    Float               @default(0) @map("relevance_score")
  expertiseScore    Float               @default(0) @map("expertise_score")
  strategicScore    Float               @default(0) @map("strategic_score")
  relationshipScore Float               @default(0) @map("relationship_score")
  breakdownJson     Json                @map("breakdown_json")
  reasonsJson       Json                @map("reasons_json")
  angleCategory     MatchAngleCategory? @map("angle_category")
  outreachDraft     String?             @map("outreach_draft") @db.Text
  outreachEdited    String?             @map("outreach_edited") @db.Text
  // v8 matching engine fields
  effectiveRankScore Float?             @map("effective_rank_score")
  selectedIntent     String?            @map("selected_intent") @db.VarChar(50)
  aiReasoning        String?            @map("ai_reasoning") @db.Text
  aiGreenFlags       Json?              @map("ai_green_flags")
  aiRedFlags         Json?              @map("ai_red_flags")
  matchLevel         String?            @map("match_level") @db.VarChar(30)
  hardFilterStatus   String?            @map("hard_filter_status") @db.VarChar(20)
  confidence         Float?
  rank               Int?
  status            PitchMatchStatus    @default(PENDING)
  savedAt           DateTime?           @map("saved_at")
  ignoredAt         DateTime?           @map("ignored_at")
  contactedAt       DateTime?           @map("contacted_at")
  archivedAt        DateTime?           @map("archived_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  pitchSection      PitchSection        @relation(fields: [pitchSectionId], references: [id], onDelete: Cascade)
  contact           Contact             @relation(fields: [contactId], references: [id])

  @@unique([pitchSectionId, contactId])
  @@index([pitchSectionId])
  @@index([contactId])
  @@index([score(sort: Desc)])
  @@index([status])
  @@index([pitchSectionId, score(sort: Desc)])
  @@map("pitch_matches")
}

/// Job tracking for pipeline steps
/// Enables resilient processing with retry and progress tracking
model PitchJob {
  id          String         @id @default(uuid())
  pitchId     String         @map("pitch_id")
  step        PitchJobStep
  status      PitchJobStatus @default(PENDING)
  progress    Int            @default(0) @db.SmallInt
  error       String?        @db.Text
  attempts    Int            @default(0) @db.SmallInt
  maxAttempts Int            @default(3) @map("max_attempts") @db.SmallInt
  startedAt   DateTime?      @map("started_at")
  completedAt DateTime?      @map("completed_at")
  bullJobId   String?        @map("bull_job_id") @db.VarChar(100)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  pitch       Pitch          @relation(fields: [pitchId], references: [id], onDelete: Cascade)

  @@unique([pitchId, step])
  @@index([pitchId])
  @@index([status])
  @@index([pitchId, step])
  @@map("pitch_jobs")
}

/// Contact profile cache for matching
/// Pre-computed profiles from IntellMatch data for fast matching
model ContactProfileCache {
  id                   String   @id @default(uuid())
  contactId            String   @unique @map("contact_id")
  userId               String   @map("user_id")
  profileSummary       String   @map("profile_summary") @db.Text
  sectors              Json
  skills               Json
  interests            Json
  keywords             Json?
  investorType         String?  @map("investor_type") @db.VarChar(50)
  investmentStage      String?  @map("investment_stage") @db.VarChar(50)
  checkSize            String?  @map("check_size") @db.VarChar(100)
  geography            String?  @db.VarChar(255)
  previousInvestments  Json?    @map("previous_investments")
  expertise            Json?
  embedding            Json?
