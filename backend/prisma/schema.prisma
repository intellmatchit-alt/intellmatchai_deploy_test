  relationshipStrength Float    @default(0) @map("relationship_strength")
  lastInteractionDays  Int?     @map("last_interaction_days")
  interactionCount     Int      @default(0) @map("interaction_count")
  isStale              Boolean  @default(false) @map("is_stale")
  builtAt              DateTime @default(now()) @map("built_at")
