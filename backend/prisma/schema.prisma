  @@index([userId])
  @@index([isStale])
  @@index([userId, isStale])
  @@map("contact_profile_cache")
}

/// User preferences for PNME feature
/// Configurable matching weights and settings
model UserPNMEPreferences {
  id                     String    @id @default(uuid())
  userId                 String    @unique @map("user_id")
  relevanceWeight        Float     @default(0.4) @map("relevance_weight")
  expertiseWeight        Float     @default(0.3) @map("expertise_weight")
