  role            TeamMemberRole   @default(MEMBER)
  status          TeamMemberStatus @default(INVITED)
  invitationToken String?          @unique @map("invitation_token") @db.VarChar(100)
  invitedAt       DateTime         @default(now()) @map("invited_at")
  joinedAt        DateTime?        @map("joined_at")
  removedAt       DateTime?        @map("removed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  opportunity     OpportunityIntent @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user            User?             @relation("OpportunityMemberUser", fields: [userId], references: [id])

  @@unique([opportunityId, userId])
  @@unique([opportunityId, externalEmail])
  @@index([opportunityId])
  @@index([userId])
  @@index([status])
  @@map("opportunity_members")
}

/// Pitch team member
model PitchMember {
  id              String           @id @default(uuid())
  pitchId         String           @map("pitch_id")
  userId          String?          @map("user_id")
  externalName    String?          @map("external_name") @db.VarChar(255)
  externalEmail   String?          @map("external_email") @db.VarChar(255)
  externalPhone   String?          @map("external_phone") @db.VarChar(50)
  role            TeamMemberRole   @default(MEMBER)
  status          TeamMemberStatus @default(INVITED)
  invitationToken String?          @unique @map("invitation_token") @db.VarChar(100)
  invitedAt       DateTime         @default(now()) @map("invited_at")
  joinedAt        DateTime?        @map("joined_at")
  removedAt       DateTime?        @map("removed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  pitch           Pitch            @relation(fields: [pitchId], references: [id], onDelete: Cascade)
  user            User?            @relation("PitchMemberUser", fields: [userId], references: [id])

