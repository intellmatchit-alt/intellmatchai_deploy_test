generator client {
  provider        = "prisma-client-js"
  binaryTargets = ["native", "windows"]
  previewFeatures = ["fullTextIndex", "fullTextSearch"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// User account model
/// Stores core user information and authentication data
model User {
  id                    String              @id @default(uuid())
  email                 String              @unique
  passwordHash          String              @map("password_hash")
  fullName              String              @map("full_name")
  title                 String?             @db.VarChar(20)
  firstName             String?             @map("first_name") @db.VarChar(100)
  middleName            String?             @map("middle_name") @db.VarChar(100)
  lastName              String?             @map("last_name") @db.VarChar(100)
  jobTitle              String?             @map("job_title")
  company               String?
  bio                   String?             @db.Text
  avatarUrl             String?             @map("avatar_url") @db.MediumText
  linkedinUrl           String?             @map("linkedin_url")
  websiteUrl            String?             @map("website_url")
  phone                 String?
  phoneCountryCode      String?             @map("phone_country_code") @db.VarChar(5)
  location              String?
  timezone              String?             @default("UTC")
  consentEnrichment     Boolean             @default(false) @map("consent_enrichment")
  consentContacts       Boolean             @default(false) @map("consent_contacts")
  consentAnalytics      Boolean             @default(false) @map("consent_analytics")
  emailVerified         Boolean             @default(false) @map("email_verified")
  isActive              Boolean             @default(true) @map("is_active")
  isAdmin               Boolean             @default(false) @map("is_admin")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  lastLoginAt           DateTime?           @map("last_login_at")
  twitterUrl            String?             @map("twitter_url")
  invitationToken       String?             @unique @map("invitation_token")
  invitedAt             DateTime?           @map("invited_at")
  invitedById           String?             @map("invited_by_id")
  status                UserStatus          @default(ACTIVE)
  onboardingCompletedAt DateTime?           @map("onboarding_completed_at")
  onboardingData        Json?               @map("onboarding_data")
  onboardingStep        Int                 @default(0) @map("onboarding_step")
  consentLogs           ConsentLog[]
  introducedContacts    Contact[]           @relation("IntroducedContacts")
  contacts              Contact[]
  interactions          Interaction[]
  matchHistory          MatchHistory[]
  matchResults          MatchResult[]
  opportunityIntents    OpportunityIntent[]
  projectMatches        ProjectMatch[]      @relation("ProjectMatchedUser")
  projects              Project[]
  refreshTokens         RefreshToken[]
  userGoals             UserGoal[]
  userHobbies           UserHobby[]
  userInterests         UserInterest[]
  userSectors           UserSector[]
  userSkills            UserSkill[]
  invitedBy             User?               @relation("UserInvites", fields: [invitedById], references: [id])
  invitedUsers          User[]              @relation("UserInvites")
  verificationTokens    VerificationToken[]
  // Messaging relations
  conversationsAsOne    Conversation[]      @relation("ConversationParticipantOne")
  conversationsAsTwo    Conversation[]      @relation("ConversationParticipantTwo")
  sentMessages          Message[]           @relation("MessageSender")
  messageReactions      MessageReaction[]   @relation("MessageReactionUser")
  // Collaboration relations
  collabRequestsFrom    CollaborationRequest[]  @relation("CollabRequestFromUser")
  collabRequestsTo      CollaborationRequest[]  @relation("CollabRequestToUser")
  introductionsAsCollab Introduction[]          @relation("IntroductionCollaborator")
  collabLedgerFrom      CollaborationLedger[]   @relation("CollabLedgerFromUser")
  collabLedgerTo        CollaborationLedger[]   @relation("CollabLedgerToUser")
  collaborationSettings CollaborationSettings?
  // Team member relations
  projectMembers        ProjectMember[]         @relation("ProjectMemberUser")
  opportunityMembers    OpportunityMember[]     @relation("OpportunityMemberUser")
  pitchMembers          PitchMember[]           @relation("PitchMemberUser")
  dealMembers           DealMember[]            @relation("DealMemberUser")
  // Other relations
  pitches               Pitch[]
  dealRequests          DealRequest[]
  events                Event[]
  eventAttendees        EventAttendee[]         @relation("EventAttendeeUser")
  collabTasksCreated    CollaborationTask[]     @relation("CollabTaskCreatedBy")
  collabTasksAssigned   CollaborationTask[]     @relation("CollabTaskAssignedTo")
  platformInvitations   PlatformInvitation[]
  orgMembers            OrganizationMember[]
  orgInvitations        OrgInvitation[]         @relation("OrgInvitedBy")
  orgActivityLogs       OrgActivityLog[]        @relation("OrgActivityUser")
  contactSharingPrefs   ContactSharingPreference[]
  sharedContacts        SharedContact[]         @relation("SharedContactBy")
  warmIntroRequester    WarmIntroRequest[]      @relation("WarmIntroRequester")
  warmIntroConnector    WarmIntroRequest[]      @relation("WarmIntroConnector")
  meetings              Meeting[]
  meetingAttendees      MeetingAttendee[]       @relation("MeetingAttendeeUser")
  contactReminders      ContactReminder[]
  contactNotes          ContactNote[]
  contactTasksOwned     ContactTask[]
  assignedTasks         ContactTask[]           @relation("AssignedTasks")
  taskCategories        TaskCategory[]
  taskRecurrences       TaskRecurrence[]
  taskSharesBy          TaskShare[]             @relation("TaskSharedBy")
  taskSharesWith        TaskShare[]             @relation("TaskSharedWith")
  taskComments          TaskComment[]
  taskActivities        TaskActivity[]
  notifications         Notification[]
  pushSubscriptions     PushSubscription[]
  sdaiaRecords          SdaiaProcessingRecord[]
  productProfile        ProductProfile?
  productMatchRuns      ProductMatchRun[]
  subscription          Subscription?
  wallet                Wallet?
  opportunityMatchesAsUser OpportunityMatch[]   @relation("OpportunityMatchedUser")
  pointPackPurchases       PointPackPurchase[]
  bugReports               BugReport[]
  // Affiliate relations
  referralCodeUsed         String?                     @map("referral_code_used") @db.VarChar(50)
  affiliate                Affiliate?
  affiliateReferrals       AffiliateReferral[]         @relation("ReferredByAffiliate")
  // Job Matching v3 relations
  hiringProfiles           HiringProfile[]             @relation("UserHiringProfiles")
  candidateProfiles        CandidateProfile[]          @relation("UserCandidateProfiles")

  @@index([email])
  @@index([company])
  @@index([invitedById])
  @@map("users")
}

/// Refresh token for JWT authentication
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique @db.VarChar(500)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent") @db.VarChar(500)
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

/// Email verification and password reset tokens
model VerificationToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique @db.VarChar(500)
  type      TokenType @default(EMAIL_VERIFICATION)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([type])
  @@map("verification_tokens")
}

/// Industry sectors
/// Supports hierarchy with parent_id for sub-sectors
model Sector {
  id             String          @id @default(uuid())
  name           String          @db.VarChar(255)
  nameAr         String?         @map("name_ar") @db.VarChar(255)
  parentId       String?         @map("parent_id")
  icon           String?         @db.VarChar(100)
  displayOrder   Int             @default(0) @map("display_order")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  contactSectors            ContactSector[]
  projectSectors            ProjectSector[]
  pitchSectors              PitchSector[]
  parent                    Sector?         @relation("SectorHierarchy", fields: [parentId], references: [id])
  children                  Sector[]        @relation("SectorHierarchy")
  userSectors               UserSector[]
  opportunityIntentSectors  OpportunityIntentSector[]

  @@index([parentId])
  @@index([isActive])
  @@map("sectors")
}

/// Professional skills
model Skill {
  id            String         @id @default(uuid())
  name          String         @unique @db.VarChar(255)
  nameAr        String?        @map("name_ar") @db.VarChar(255)
  category      String?        @db.VarChar(100)
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  contactSkills          ContactSkill[]
  projectSkills          ProjectSkill[]
  pitchSkills            PitchSkill[]
  userSkills             UserSkill[]
  opportunityIntentSkills OpportunityIntentSkill[]

  @@index([category])
  @@index([isActive])
  @@map("skills")
}

/// Personal/professional interests
model Interest {
  id               String            @id @default(uuid())
  name             String            @unique @db.VarChar(255)
  nameAr           String?           @map("name_ar") @db.VarChar(255)
  category         String?           @db.VarChar(100)
  icon             String?           @db.VarChar(100)
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at")
  contactInterests ContactInterest[]
  userInterests    UserInterest[]

  @@index([category])
  @@index([isActive])
  @@map("interests")
}

/// User-Sector relationship
model UserSector {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  sectorId        String   @map("sector_id")
  isPrimary       Boolean  @default(false) @map("is_primary")
  experienceYears Int?     @map("experience_years")
  createdAt       DateTime @default(now()) @map("created_at")
  sector          Sector   @relation(fields: [sectorId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sectorId])
  @@index([userId])
  @@index([sectorId])
  @@map("user_sectors")
}

/// User-Skill relationship
model UserSkill {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  skillId          String            @map("skill_id")
  proficiencyLevel ProficiencyLevel? @map("proficiency_level")
  isVerified       Boolean           @default(false) @map("is_verified")
  createdAt        DateTime          @default(now()) @map("created_at")
  skill            Skill             @relation(fields: [skillId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
  @@map("user_skills")
}

/// User-Interest relationship
model UserInterest {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  interestId String    @map("interest_id")
  intensity  Intensity @default(MODERATE)
  createdAt  DateTime  @default(now()) @map("created_at")
  interest   Interest  @relation(fields: [interestId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, interestId])
  @@index([userId])
  @@index([interestId])
  @@map("user_interests")
}

/// Hobbies for personal interests
model Hobby {
  id             String         @id @default(uuid())
  name           String         @unique @db.VarChar(255)
  nameAr         String?        @map("name_ar") @db.VarChar(255)
  category       String?        @db.VarChar(100)
  icon           String?        @db.VarChar(100)
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  contactHobbies ContactHobby[]
  userHobbies    UserHobby[]

  @@index([category])
  @@index([isActive])
  @@map("hobbies")
}

/// User-Hobby relationship
model UserHobby {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  hobbyId   String   @map("hobby_id")
  createdAt DateTime @default(now()) @map("created_at")
  hobby     Hobby    @relation(fields: [hobbyId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hobbyId])
  @@index([userId])
  @@index([hobbyId])
  @@map("user_hobbies")
}

/// User networking goals
model UserGoal {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  goalType    GoalType @map("goal_type")
  description String?  @db.Text
  priority    Int      @default(1)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([goalType])
  @@map("user_goals")
}

/// External contact/connection
model Contact {
  id                     String              @id @default(uuid())
  ownerId                String              @map("owner_id")
  fullName               String              @map("full_name") @db.VarChar(255)
  title                  String?             @db.VarChar(20)
  firstName              String?             @map("first_name") @db.VarChar(100)
  middleName             String?             @map("middle_name") @db.VarChar(100)
  lastName               String?             @map("last_name") @db.VarChar(100)
  email                  String?             @db.VarChar(255)
  phone                  String?             @db.VarChar(50)
  phoneCountryCode       String?             @map("phone_country_code") @db.VarChar(5)
  company                String?             @db.VarChar(255)
  jobTitle               String?             @map("job_title") @db.VarChar(255)
  website                String?             @db.VarChar(500)
  linkedinUrl            String?             @map("linkedin_url") @db.VarChar(500)
  notes                  String?             @db.Text
  source                 ContactSource       @default(MANUAL)
  rawOcrText             String?             @map("raw_ocr_text") @db.Text
  cardImageUrl           String?             @map("card_image_url") @db.VarChar(500)
  isEnriched             Boolean             @default(false) @map("is_enriched")
  enrichmentData         Json?               @map("enrichment_data")
  matchScore             Decimal?            @map("match_score") @db.Decimal(5, 2)
  lastInteractionAt      DateTime?           @map("last_interaction_at")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  bio                    String?             @db.Text
  enrichedAt             DateTime?           @map("enriched_at")
  location               String?             @db.VarChar(255)
  avatarUrl              String?             @map("avatar_url") @db.MediumText
  dataConfidence         DataConfidence      @default(LOW) @map("data_confidence")
  identityKey            String?             @map("identity_key") @db.VarChar(255)
  importBatchId          String?             @map("import_batch_id")
  importSource           ImportSource?       @map("import_source")
  normalizedEmail        String?             @map("normalized_email") @db.VarChar(255)
  normalizedPhone        String?             @map("normalized_phone") @db.VarChar(20)
  rawContactJson         Json?               @map("raw_contact_json")
  rawSources             Json                @map("raw_sources")
  bioFull                String?             @map("bio_full") @db.Text
  bioSummary             String?             @map("bio_summary") @db.VarChar(500)
  collaborationMissionId String?             @map("collaboration_mission_id")
  introducedByUserId     String?             @map("introduced_by_user_id")
  introductionId         String?             @map("introduction_id")
  isFavorite             Boolean             @default(false) @map("is_favorite")
  organizationId         String?             @map("organization_id")
  organization           Organization?       @relation(fields: [organizationId], references: [id])
  contactHobbies         ContactHobby[]
  contactInterests       ContactInterest[]
  contactNotes           ContactNote[]
  reminders              ContactReminder[]
  contactSectors         ContactSector[]
  contactSkills          ContactSkill[]
  suggestions            ContactSuggestion[]
  tasks                  ContactTask[]
  importBatch            ContactImportBatch? @relation("ImportedContacts", fields: [importBatchId], references: [id])
  introducedByUser       User?               @relation("IntroducedContacts", fields: [introducedByUserId], references: [id])
  owner                  User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  interactions           Interaction[]
  matchHistory           MatchHistory[]
  matchResults           MatchResult[]
  projectMatches         ProjectMatch[]
  collaborationRequests  CollaborationRequest[]
  collaborationMatchResults CollaborationMatchResult[]
  opportunityMatchesAsContact OpportunityMatch[]  @relation("OpportunityMatchedContact")
  meetingContacts        Meeting[]               @relation("MeetingContact")
  meetingAttendeeContacts MeetingAttendee[]      @relation("MeetingAttendeeContact")
  platformInvitationsFor PlatformInvitation[]
  sdaiaSubjectRecords    SdaiaProcessingRecord[] @relation("SdaiaSubjectContact")
  sharedContacts         SharedContact[]
  warmIntroTargets       WarmIntroRequest[]
  dealMatchResults       DealMatchResult[]
  pitchMatches           PitchMatch[]
  productMatchResults    ProductMatchResult[]
  taskAssignments        TaskAssignee[]

  @@index([ownerId])
  @@index([ownerId, createdAt(sort: Desc)])
  @@index([ownerId, matchScore(sort: Desc)])
  @@index([email])
  @@index([company])
  @@index([source])
  @@index([createdAt])
  @@index([lastInteractionAt])
  @@index([ownerId, normalizedPhone])
  @@index([ownerId, normalizedEmail])
  @@index([ownerId, identityKey])
  @@index([ownerId, dataConfidence])
  @@index([importBatchId])
  @@index([introducedByUserId], map: "contacts_introduced_by_user_id_fkey")
  @@index([organizationId])
  @@index([ownerId, isFavorite])
  @@fulltext([fullName, firstName, lastName, company, notes])
  @@map("contacts")
}

/// Contact-Sector relationship
model ContactSector {
  id         String       @id @default(uuid())
  contactId  String       @map("contact_id")
  sectorId   String       @map("sector_id")
  confidence Decimal      @default(1.00) @db.Decimal(3, 2)
  source     SectorSource @default(USER)
  createdAt  DateTime     @default(now()) @map("created_at")
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sector     Sector       @relation(fields: [sectorId], references: [id])

  @@unique([contactId, sectorId])
  @@index([contactId])
  @@index([sectorId])
  @@map("contact_sectors")
}

/// Contact-Skill relationship
model ContactSkill {
  id         String       @id @default(uuid())
  contactId  String       @map("contact_id")
  skillId    String       @map("skill_id")
  confidence Decimal      @default(1.00) @db.Decimal(3, 2)
  source     SectorSource @default(USER)
  createdAt  DateTime     @default(now()) @map("created_at")
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  skill      Skill        @relation(fields: [skillId], references: [id])

  @@unique([contactId, skillId])
  @@index([contactId])
  @@index([skillId])
  @@map("contact_skills")
}

/// Contact-Interest relationship
model ContactInterest {
  id         String       @id @default(uuid())
  contactId  String       @map("contact_id")
  interestId String       @map("interest_id")
  confidence Decimal      @default(1.00) @db.Decimal(3, 2)
  source     SectorSource @default(USER)
  createdAt  DateTime     @default(now()) @map("created_at")
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  interest   Interest     @relation(fields: [interestId], references: [id])

  @@unique([contactId, interestId])
  @@index([contactId])
  @@index([interestId])
  @@map("contact_interests")
}

/// Contact-Hobby relationship
model ContactHobby {
  id         String       @id @default(uuid())
  contactId  String       @map("contact_id")
  hobbyId    String       @map("hobby_id")
  confidence Decimal      @default(1.00) @db.Decimal(3, 2)
  source     SectorSource @default(USER)
  createdAt  DateTime     @default(now()) @map("created_at")
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  hobby      Hobby        @relation(fields: [hobbyId], references: [id])

  @@unique([contactId, hobbyId])
  @@index([contactId])
  @@index([hobbyId])
  @@map("contact_hobbies")
}

/// AI suggestions for contact fields
model ContactSuggestion {
  id         String   @id @default(uuid())
  contactId  String   @map("contact_id")
  field      String   @db.VarChar(100)
  value      String   @db.Text
  confidence Decimal  @db.Decimal(3, 2)
  source     String   @db.VarChar(100)
  isAccepted Boolean? @map("is_accepted")
  createdAt  DateTime @default(now()) @map("created_at")
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_suggestions")
}

/// Interaction between user and contact
model Interaction {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  contactId       String          @map("contact_id")
  interactionType InteractionType @map("interaction_type")
  metadata        Json?
  occurredAt      DateTime        @default(now()) @map("occurred_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  contact         Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, contactId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, occurredAt(sort: Desc)])
  @@index([interactionType])
  @@index([occurredAt])
  @@index([createdAt])
  @@index([contactId], map: "interactions_contact_id_fkey")
  @@map("interactions")
}

/// Cached match results
model MatchResult {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  contactId        String    @map("contact_id")
  recombeeScore    Decimal?  @map("recombee_score") @db.Decimal(5, 4)
  cohereScore      Decimal?  @map("cohere_score") @db.Decimal(5, 4)
  finalScore       Decimal   @map("final_score") @db.Decimal(5, 2)
  intersectionTags Json?     @map("intersection_tags")
  aiReasons        Json?     @map("ai_reasons")
  suggestedMessage String?   @map("suggested_message") @db.Text
  expiresAt        DateTime? @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  contact          Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId])
  @@index([userId, finalScore(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([contactId])
  @@index([createdAt])
  @@index([finalScore])
  @@map("match_results")
}

/// Match History - tracks historical match scores over time
/// Used for analytics, trend analysis, and ML model improvement
model MatchHistory {
  id                       String   @id @default(uuid())
  userId                   String   @map("user_id")
  contactId                String   @map("contact_id")
  matchType                String   @default("contact") @map("match_type")
  totalScore               Int      @map("total_score")
  goalAlignmentScore       Int?     @map("goal_alignment_score")
  sectorScore              Int?     @map("sector_score")
  skillScore               Int?     @map("skill_score")
  semanticSimilarityScore  Int?     @map("semantic_similarity_score")
  networkProximityScore    Int?     @map("network_proximity_score")
  complementarySkillsScore Int?     @map("complementary_skills_score")
  recencyScore             Int?     @map("recency_score")
  interactionScore         Int?     @map("interaction_score")
  interestScore            Int?     @map("interest_score")
  hobbyScore               Int?     @map("hobby_score")
  networkDegree            Int?     @map("network_degree")
  calculationMethod        String   @default("deterministic") @map("calculation_method")
  intersections            Json?
  reasons                  Json?
  calculatedAt             DateTime @default(now()) @map("calculated_at")
  contact                  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, calculatedAt(sort: Desc)])
  @@index([userId, contactId])
  @@index([contactId])
  @@index([totalScore(sort: Desc)])
  @@index([calculatedAt])
  @@index([matchType])
  @@map("match_history")
}

/// Consent audit log (GDPR compliance)
model ConsentLog {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  consentType ConsentType   @map("consent_type")
  action      ConsentAction
  ipAddress   String?       @map("ip_address") @db.VarChar(45)
  userAgent   String?       @map("user_agent") @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
  @@map("consent_logs")
}

/// Business project for collaboration matching
model Project {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  title           String            @db.VarChar(200)
  summary         String            @db.Text
  detailedDesc    String?           @map("detailed_desc") @db.Text
  category        String?           @db.VarChar(100)
  stage           ProjectStage      @default(IDEA)
  investmentRange String?           @map("investment_range") @db.VarChar(255)
  timeline        String?           @db.Text
  lookingFor      Json              @map("looking_for")
  keywords        Json
  metadata        Json?
  // New structured fields
  needs                    Json?               @map("needs")
  markets                  Json?               @map("markets")
  fundingAskMin            Int?                @map("funding_ask_min")
  fundingAskMax            Int?                @map("funding_ask_max")
  tractionSignals          Json?               @map("traction_signals")
  advisoryTopics           Json?               @map("advisory_topics")
  partnerTypeNeeded        Json?               @map("partner_type_needed")
  commitmentLevelNeeded    String?             @map("commitment_level_needed") @db.VarChar(50)
  idealCounterpartProfile  String?             @map("ideal_counterpart_profile") @db.Text
  targetCustomerTypes      Json?               @map("target_customer_types")
  engagementModel          Json?               @map("engagement_model")
  strictLookingFor         Boolean             @default(false) @map("strict_looking_for")
  documentUrl              String?             @map("document_url") @db.VarChar(500)
  documentName             String?             @map("document_name") @db.VarChar(255)
  // v2 matching fields
  fieldEmbeddings          Json?               @map("field_embeddings")
  normalizedNeedSignals    Json?               @map("normalized_need_signals")
  dataQualityScore         Int?                @map("data_quality_score")
  visibility      ProjectVisibility @default(PUBLIC)
  isActive        Boolean           @default(true) @map("is_active")
  organizationId  String?           @map("organization_id")
  isTeamShared    Boolean           @default(false) @map("is_team_shared")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  matches         ProjectMatch[]
  sectors         ProjectSector[]
  skillsNeeded    ProjectSkill[]
  organization    Organization?     @relation(fields: [organizationId], references: [id])
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  members         ProjectMember[]
  collaborationRequests CollaborationRequest[]
  collaborationTasks    CollaborationTask[]

  @@index([userId])
  @@index([isActive])
  @@index([visibility])
  @@index([createdAt(sort: Desc)])
  @@index([organizationId, isTeamShared])
  @@map("projects")
}

/// Project-Sector relationship
model ProjectSector {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  sectorId  String   @map("sector_id")
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sector    Sector   @relation(fields: [sectorId], references: [id])

  @@unique([projectId, sectorId])
  @@index([projectId])
  @@index([sectorId])
  @@map("project_sectors")
}

/// Project-Skill relationship (skills needed for the project)
model ProjectSkill {
  id         String          @id @default(uuid())
  projectId  String          @map("project_id")
  skillId    String          @map("skill_id")
  importance SkillImportance @default(REQUIRED)
  createdAt  DateTime        @default(now()) @map("created_at")
  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill      Skill           @relation(fields: [skillId], references: [id])

  @@unique([projectId, skillId])
  @@index([projectId])
  @@index([skillId])
  @@map("project_skills")
}

/// Project match result (matched users or contacts)
model ProjectMatch {
  id               String             @id @default(uuid())
  projectId        String             @map("project_id")
  matchedUserId    String?            @map("matched_user_id")
  matchedContactId String?            @map("matched_contact_id")
  matchScore       Float              @map("match_score")
  matchType        String             @map("match_type")
  reasons          Json
  suggestedAction  String?            @map("suggested_action")
  suggestedMessage       String?            @map("suggested_message") @db.Text
  suggestedMessageEdited String?            @map("suggested_message_edited") @db.Text
  sharedSectors          Json               @map("shared_sectors")
  sharedSkills           Json               @map("shared_skills")
  sharedInterests        Json               @map("shared_interests")
  // v2 matching engine fields
  deterministicScore     Float?             @map("deterministic_score")
  aiScore                Float?             @map("ai_score")
  finalScore             Float?             @map("final_score")
  confidence             Float?
  matchLevel             String?            @map("match_level") @db.VarChar(30)
  hardFilterStatus       String?            @map("hard_filter_status") @db.VarChar(20)
  hardFilterReason       String?            @map("hard_filter_reason") @db.VarChar(100)
  scoreBreakdown         Json?              @map("score_breakdown")
  explanation            Json?
  intent                 String?            @db.VarChar(50)
  rank                   Int?
  expiresAt              DateTime?          @map("expires_at")
  status                 ProjectMatchStatus @default(PENDING)
  archivedAt       DateTime?          @map("archived_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  sharedHobbies    Json               @map("shared_hobbies")
  matchedContact   Contact?           @relation(fields: [matchedContactId], references: [id])
  matchedUser      User?              @relation("ProjectMatchedUser", fields: [matchedUserId], references: [id])
  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, matchedUserId])
  @@unique([projectId, matchedContactId])
  @@index([projectId])
  @@index([matchedUserId])
  @@index([matchedContactId])
  @@index([matchScore(sort: Desc)])
  @@index([status])
  @@map("project_matches")
}

/// Contact reminder for notes
/// Allows users to set reminders that appear on dashboard
model ContactReminder {
  id          String    @id @default(uuid())
  contactId   String?   @map("contact_id")
  userId      String    @map("user_id")
  title       String    @db.VarChar(255)
  description String?   @db.Text
  reminderAt  DateTime  @map("reminder_at")
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  imageUrls   Json?     @map("image_urls")
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([userId])
  @@index([reminderAt])
  @@index([isCompleted])
  @@index([userId, reminderAt])
  @@index([userId, isCompleted, reminderAt])
  @@map("contact_reminders")
}

/// Contact note with rich media support
/// Allows text, image, or voice notes attached to contacts
model ContactNote {
  id        String   @id @default(uuid())
  contactId String   @map("contact_id")
  userId    String   @map("user_id")
  type      NoteType @default(TEXT)
  content   String?  @db.Text
  mediaUrl  String?  @map("media_url") @db.VarChar(500)
  mimeType  String?  @map("mime_type") @db.VarChar(100)
  fileName  String?  @map("file_name") @db.VarChar(255)
  fileSize  Int?     @map("file_size")
  duration  Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([userId])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@map("contact_notes")
}

/// Contact task
/// Tasks associated with contacts (optional) that appear on dashboard
model ContactTask {
  id           String       @id @default(uuid())
  contactId    String?      @map("contact_id")
  userId       String       @map("user_id")
  title        String       @db.VarChar(255)
  description  String?      @db.Text
  voiceNoteUrl String?      @map("voice_note_url") @db.VarChar(500)
  dueDate      DateTime?    @map("due_date")
  reminderAt   DateTime?    @map("reminder_at")
  priority     TaskPriority @default(MEDIUM)
  status       TaskStatus   @default(PENDING)
  completedAt  DateTime?    @map("completed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  imageUrls    Json?        @map("image_urls")
  category     String?      @db.VarChar(100)
  categoryColor String?     @map("category_color") @db.VarChar(20)
  recurrenceId  String?      @map("recurrence_id")
  assignedToId  String?      @map("assigned_to_id")
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo    User?        @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  meeting       Meeting?
  recurrence    TaskRecurrence? @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)
  reminders     TaskReminder[]
