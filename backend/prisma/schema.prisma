/// Contact Import Batch - tracks each import operation
model ContactImportBatch {
  id                     String            @id @default(uuid())
  userId                 String            @map("user_id")
  source                 ImportSource
  status                 ImportBatchStatus @default(PENDING)
  consentedAt            DateTime          @map("consented_at")
  enrichmentEnabled      Boolean           @default(false) @map("enrichment_enabled")
  aiSummaryEnabled       Boolean           @default(false) @map("ai_summary_enabled")
  phoneEnrichmentEnabled Boolean           @default(false) @map("phone_enrichment_enabled")
  currentStage           String?           @map("current_stage") @db.VarChar(50)
  stageProgress          Int               @default(0) @map("stage_progress") @db.SmallInt
  overallProgress        Int               @default(0) @map("overall_progress") @db.SmallInt
  totalReceived          Int               @default(0) @map("total_received")
  totalImported          Int               @default(0) @map("total_imported")
  duplicatesMerged       Int               @default(0) @map("duplicates_merged")
  enrichedCount          Int               @default(0) @map("enriched_count")
  taggedCount            Int               @default(0) @map("tagged_count")
  summarizedCount        Int               @default(0) @map("summarized_count")
  matchedCount           Int               @default(0) @map("matched_count")
  failedCount            Int               @default(0) @map("failed_count")
  errorMessage           String?           @map("error_message") @db.Text
  errorDetails           Json?             @map("error_details")
  currentJobId           String?           @map("current_job_id") @db.VarChar(100)
  startedAt              DateTime?         @map("started_at")
  completedAt            DateTime?         @map("completed_at")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  contacts               Contact[]         @relation("ImportedContacts")

  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@map("contact_import_batches")
}

/// Import Audit Log - tracks all import/delete operations
model ImportAuditLog {
  id        String   @id @default(uuid())
  batchId   String   @map("batch_id")
  userId    String   @map("user_id")
  action    String   @db.VarChar(50)
  details   Json?
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([batchId])
  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("import_audit_logs")
}

/// Contact Computed Profile - stores extracted/computed data
model ContactComputedProfile {
  id                String         @id @default(uuid())
  contactId         String         @unique @map("contact_id")
  sectorsJson       Json           @map("sectors_json")
  skillsJson        Json           @map("skills_json")
  interestsJson     Json           @map("interests_json")
  keywordsJson      Json           @map("keywords_json")
  profileSummary    String?        @map("profile_summary") @db.Text
  summarySource     String?        @map("summary_source") @db.VarChar(20)
  overallConfidence Float          @default(0) @map("overall_confidence")
  confidenceLevel   DataConfidence @default(LOW) @map("confidence_level")
  confidenceJson    Json?          @map("confidence_json")
  lastEnrichedAt    DateTime?      @map("last_enriched_at")
  lastTaggedAt      DateTime?      @map("last_tagged_at")
  lastSummarizedAt  DateTime?      @map("last_summarized_at")
  enrichmentSource  String?        @map("enrichment_source") @db.VarChar(50)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@index([contactId])
  @@index([confidenceLevel])
  @@map("contact_computed_profiles")
}

/// Contact Match Cache - stores precomputed match scores
model ContactMatchCache {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  contactId          String    @map("contact_id")
  score              Int       @db.SmallInt
  breakdownJson      Json      @map("breakdown_json")
  reasonsJson        Json      @map("reasons_json")
  version            Int       @default(1)
  computedAt         DateTime  @map("computed_at")
  expiresAt          DateTime? @map("expires_at")
  userProfileHash    String?   @map("user_profile_hash") @db.VarChar(64)
  contactProfileHash String?   @map("contact_profile_hash") @db.VarChar(64)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@unique([userId, contactId])
  @@index([userId])
  @@index([userId, score(sort: Desc)])
  @@index([contactId])
  @@index([expiresAt])
  @@map("contact_match_cache")
}

/// User Import Consent - stores consent records
model UserImportConsent {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  consentVersion    String   @map("consent_version") @db.VarChar(20)
  enrichmentConsent Boolean  @default(false) @map("enrichment_consent")
  aiSummaryConsent  Boolean  @default(false) @map("ai_summary_consent")
  ipAddress         String?  @map("ip_address") @db.VarChar(45)
  userAgent         String?  @map("user_agent") @db.VarChar(500)
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("user_import_consents")
}

/// User subscription information
model Subscription {
  id                 String             @id @default(uuid())
  userId             String             @unique @map("user_id")
  plan               SubscriptionPlan   @default(FREE)
  status             SubscriptionStatus @default(TRIALING)
  billingInterval    BillingInterval?   @map("billing_interval")
  seats              Int                @default(1)
  trialEndsAt        DateTime?          @map("trial_ends_at")
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  cancelledAt        DateTime?          @map("cancelled_at")
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization?
  payments           Payment[]

  @@index([userId])
  @@index([status])
  @@index([plan])
  @@map("subscriptions")
}

/// Payment records from PayTabs
model Payment {
  id              String           @id @default(uuid())
  subscriptionId  String           @map("subscription_id")
  tranRef         String?          @unique @map("tran_ref")
  cartId          String           @unique @map("cart_id")
  amount          Decimal          @db.Decimal(10, 2)
  currency        String           @default("USD") @db.VarChar(3)
  status          PaymentStatus    @default(PENDING)
  responseCode    String?          @map("response_code")
  responseMessage String?          @map("response_message") @db.Text
  callbackPayload Json?            @map("callback_payload")
  customerEmail   String           @map("customer_email")
  customerName    String           @map("customer_name")
  description     String?          @db.Text
  billingInterval BillingInterval  @map("billing_interval")
  plan            SubscriptionPlan
  seats           Int              @default(1)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  paidAt          DateTime?        @map("paid_at")
  subscription    Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([tranRef])
  @@index([cartId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

/// Point pack purchase via payment gateway
model PointPackPurchase {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  packId          String        @map("pack_id")
  cartId          String        @unique @map("cart_id")
  tranRef         String?       @unique @map("tran_ref")
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD") @db.VarChar(3)
  points          Int
  status          PaymentStatus @default(PENDING)
  responseCode    String?       @map("response_code")
  responseMessage String?       @map("response_message") @db.Text
  callbackPayload Json?         @map("callback_payload")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  paidAt          DateTime?     @map("paid_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointPack PointPack @relation(fields: [packId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("point_pack_purchases")
}

/// Event created by a host for networking
model Event {
  id             String   @id @default(uuid())
  hostId         String   @map("host_id")
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  dateTime       DateTime @map("date_time")
  location       String?  @db.VarChar(500)
  locationLat    Float?   @map("location_lat")
  locationLng    Float?   @map("location_lng")
  thumbnailUrl   String?  @map("thumbnail_url") @db.VarChar(500)
  welcomeMessage String?  @map("welcome_message") @db.Text
  uniqueCode     String   @unique @map("unique_code") @db.VarChar(20)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  host           User     @relation(fields: [hostId], references: [id])
  attendees      EventAttendee[]

  @@index([hostId])
  @@index([uniqueCode])
  @@index([dateTime])
  @@index([isActive])
  @@map("events")
}

/// Attendee registered for an event (guest or logged-in user)
model EventAttendee {
  id          String    @id @default(uuid())
  eventId     String    @map("event_id")
  userId      String?   @map("user_id")
  email       String    @db.VarChar(255)
  name        String    @db.VarChar(255)
  mobile      String?   @db.VarChar(50)
  company     String?   @db.VarChar(255)
  role        String?   @db.VarChar(255)
  bio         String?   @db.Text
  lookingFor  String?   @map("looking_for") @db.Text
  cvUrl       String?   @map("cv_url") @db.VarChar(500)
  photoUrl    String?   @map("photo_url") @db.VarChar(500)
  isHost      Boolean   @default(false) @map("is_host")
  accessToken String?   @map("access_token") @db.VarChar(100)
  tokenExpiry DateTime? @map("token_expiry")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User?     @relation("EventAttendeeUser", fields: [userId], references: [id])
  matchesAsSource  EventAttendeeMatch[] @relation("AttendeeMatchSource")
  matchesAsTarget  EventAttendeeMatch[] @relation("AttendeeMatchTarget")

  @@unique([eventId, email])
  @@index([eventId])
  @@index([userId])
  @@index([email])
  @@index([accessToken])
  @@map("event_attendees")
}

/// Match result between two event attendees
model EventAttendeeMatch {
  id                String          @id @default(uuid())
  attendeeId        String          @map("attendee_id")
  matchedAttendeeId String          @map("matched_attendee_id")
  matchLevel        EventMatchLevel @map("match_level")
  score             Int             @default(0)
  reasons           String?         @db.Text
  createdAt         DateTime        @default(now()) @map("created_at")
  attendee          EventAttendee   @relation("AttendeeMatchSource", fields: [attendeeId], references: [id], onDelete: Cascade)
  matchedAttendee   EventAttendee   @relation("AttendeeMatchTarget", fields: [matchedAttendeeId], references: [id], onDelete: Cascade)

  @@unique([attendeeId, matchedAttendeeId])
  @@index([attendeeId])
  @@index([matchedAttendeeId])
  @@index([matchLevel])
  @@map("event_attendee_matches")
}

/// Itemized match result - stores complete per-criterion breakdown
model ItemizedMatchResult {
  id              String            @id @default(uuid())
  matchType       ItemizedMatchType @map("match_type")
  sourceId        String            @map("source_id")
  sourceType      MatchEntityType   @map("source_type")
  sourceName      String            @map("source_name") @db.VarChar(255)
  targetId        String            @map("target_id")
  targetType      MatchEntityType   @map("target_type")
  targetName      String            @map("target_name") @db.VarChar(255)
  perfectCount    Int               @default(0) @map("perfect_count") @db.SmallInt
  excellentCount  Int               @default(0) @map("excellent_count") @db.SmallInt
  strongCount     Int               @default(0) @map("strong_count") @db.SmallInt
  moderateCount   Int               @default(0) @map("moderate_count") @db.SmallInt
  weakCount       Int               @default(0) @map("weak_count") @db.SmallInt
  noMatchCount    Int               @default(0) @map("no_match_count") @db.SmallInt
  criticalMet     Int               @default(0) @map("critical_met") @db.SmallInt
  criticalTotal   Int               @default(0) @map("critical_total") @db.SmallInt
  concernsJson    Json?             @map("concerns_json")
  suggestedAction String?           @map("suggested_action") @db.VarChar(255)
  actionReason    String?           @map("action_reason") @db.Text
  messageTemplate String?           @map("message_template") @db.Text
  iceBreakersJson Json?             @map("ice_breakers_json")
  expiresAt       DateTime?         @map("expires_at")
  calculatedAt    DateTime          @default(now()) @map("calculated_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  criteria        ItemizedMatchCriterion[]

  @@unique([matchType, sourceId, targetId])
  @@index([matchType])
  @@index([sourceId])
  @@index([targetId])
  @@index([sourceId, targetId])
  @@index([matchType, sourceId])
  @@index([expiresAt])
  @@map("itemized_match_results")
}

/// Individual criterion score within an itemized match
model ItemizedMatchCriterion {
  id           String               @id @default(uuid())
  resultId     String               @map("result_id")
  criterionId  String               @map("criterion_id") @db.VarChar(50)
  name         String               @db.VarChar(100)
  icon         String               @db.VarChar(50)
  score        Int                  @db.SmallInt
  status       CriterionMatchStatus
  importance   CriterionImportance
  matchType    CriterionMatchType   @map("match_type")
  summary      String               @db.Text
  sourceValue  String               @map("source_value") @db.Text
  targetValue  String               @map("target_value") @db.Text
  detailsJson  Json                 @map("details_json")
  rawDataJson  Json?                @map("raw_data_json")
  displayOrder Int                  @default(0) @map("display_order") @db.SmallInt
  createdAt    DateTime             @default(now()) @map("created_at")
  result       ItemizedMatchResult  @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([resultId, criterionId])
  @@index([resultId])
  @@index([criterionId])
  @@index([resultId, status])
  @@index([resultId, importance])
  @@map("itemized_match_criteria")
}

/// Direct message conversation between two users
model Conversation {
  id               String    @id @default(uuid())
  participantOneId String    @map("participant_one_id")
  participantTwoId String    @map("participant_two_id")
  lastMessageAt    DateTime? @map("last_message_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  participantOne   User      @relation("ConversationParticipantOne", fields: [participantOneId], references: [id])
  participantTwo   User      @relation("ConversationParticipantTwo", fields: [participantTwoId], references: [id])
  messages         Message[]

  @@unique([participantOneId, participantTwoId])
  @@index([participantOneId])
  @@index([participantTwoId])
  @@index([lastMessageAt])
  @@map("conversations")
}

/// Direct message in a conversation
model Message {
  id             String        @id @default(uuid())
  conversationId String        @map("conversation_id")
  senderId       String        @map("sender_id")
  content        String?       @db.Text
  messageType    MessageType   @default(TEXT) @map("message_type")
  status         MessageStatus @default(SENT)
  readAt         DateTime?     @map("read_at")
  isEdited       Boolean       @default(false) @map("is_edited")
  editedAt       DateTime?     @map("edited_at")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User          @relation("MessageSender", fields: [senderId], references: [id])
  attachments    MessageAttachment[]
  reactions      MessageReaction[]

  @@index([conversationId])
  @@index([senderId])
  @@index([conversationId, createdAt])
  @@index([conversationId, status])
  @@map("messages")
}

/// Attachment for a message (image, video, audio, voice, file)
model MessageAttachment {
  id            String   @id @default(uuid())
  messageId     String   @map("message_id")
  fileName      String   @map("file_name") @db.VarChar(500)
  originalName  String   @map("original_name") @db.VarChar(500)
  mimeType      String   @map("mime_type") @db.VarChar(100)
  size          Int
  storageKey    String   @map("storage_key") @db.VarChar(500)
  storageBucket String   @map("storage_bucket") @db.VarChar(100)
  url           String   @db.VarChar(1000)
  duration      Float?
  createdAt     DateTime @default(now()) @map("created_at")
  message       Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

