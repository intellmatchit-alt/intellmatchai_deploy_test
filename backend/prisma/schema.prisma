  minMatchScore          Int       @default(50) @map("min_match_score") @db.SmallInt
  maxMatchesPerSection   Int       @default(10) @map("max_matches_per_section") @db.SmallInt
  consentGivenAt         DateTime? @map("consent_given_at")
  consentVersion         String?   @map("consent_version") @db.VarChar(20)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@map("user_pnme_preferences")
}

/// Deal Request model
/// Stores user's deal request with mode (SELL/BUY)
model DealRequest {
  id                String                @id @default(uuid())
  userId            String                @map("user_id")
  mode              DealMode
  title             String?               @db.VarChar(255)
  domain            String?               @db.VarChar(100)
  solutionType      String?               @map("solution_type") @db.VarChar(100)
  companySize       DealCompanySize?      @map("company_size")
  problemStatement  String?               @map("problem_statement") @db.Text
  targetEntityType  DealTargetEntityType? @map("target_entity_type")
  productName       String?               @map("product_name") @db.VarChar(255)
  targetDescription String?               @map("target_description") @db.Text
  metadata          Json?
  // v4 matching fields
  dataQualityScore  Int?                  @map("data_quality_score")
  embedding         Json?
  tags              Json?
  buyerRole         String?               @map("buyer_role") @db.VarChar(50)
  status            DealStatus            @default(DRAFT)
  matchCount        Int                   @default(0) @map("match_count")
  avgScore          Int                   @default(0) @map("avg_score")
