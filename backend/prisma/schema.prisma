/// Video provider type
enum VideoType {
  YOUTUBE
  VIMEO
}

/// Video category for organizing gallery videos
model VideoCategory {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  nameAr    String?  @map("name_ar") @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  videos Video[]

  @@map("video_categories")
}

/// Tag for video gallery videos
model VideoTag {
  id        String             @id @default(uuid())
  name      String             @unique @db.VarChar(100)
  nameAr    String?            @map("name_ar") @db.VarChar(100)
  isActive  Boolean            @default(true) @map("is_active")
  createdAt DateTime           @default(now()) @map("created_at")

  videos VideoTagRelation[]

  @@map("video_tags")
}

/// External video for gallery (YouTube/Vimeo)
model Video {
  id            String        @id @default(uuid())
  title         String        @db.VarChar(255)
  titleAr       String?       @map("title_ar") @db.VarChar(255)
  description   String?       @db.Text
  descriptionAr String?       @map("description_ar") @db.Text
  videoUrl      String        @map("video_url") @db.VarChar(500)
  videoType     VideoType     @map("video_type")
  videoId       String        @map("video_id") @db.VarChar(100)
  thumbnailUrl  String?       @map("thumbnail_url") @db.VarChar(500)
  duration      String?       @db.VarChar(20)
  categoryId    String        @map("category_id")
  sortOrder     Int           @default(0) @map("sort_order")
  isActive      Boolean       @default(true) @map("is_active")
  isFeatured    Boolean       @default(false) @map("is_featured")
  viewCount     Int           @default(0) @map("view_count")
  likeCount     Int           @default(0) @map("like_count")
  shareCount    Int           @default(0) @map("share_count")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  category VideoCategory @relation(fields: [categoryId], references: [id])
  tags     VideoTagRelation[]

  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@map("videos")
}

/// Join table for Video-Tag many-to-many
model VideoTagRelation {
  id      String @id @default(uuid())
  videoId String @map("video_id")
  tagId   String @map("tag_id")

  video Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  tag   VideoTag @relation(fields: [tagId], references: [id])

  @@unique([videoId, tagId])
  @@map("video_tag_relations")
}

// ============================================================================
// JOB MATCHING ENGINE V3
// ============================================================================

enum JobSeniority {
  INTERN
  JUNIOR
  MID
  SENIOR
  LEAD
  MANAGER
  DIRECTOR
  VP
  C_LEVEL
  FOUNDER
}

enum JobWorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum JobEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum JobHiringUrgency {
  LOW
  NORMAL
  URGENT
  CRITICAL
}

enum JobAvailability {
  IMMEDIATELY
  WITHIN_2_WEEKS
  WITHIN_1_MONTH
  WITHIN_3_MONTHS
  NOT_ACTIVELY_LOOKING
}

enum JobMatchLevel {
  POOR
  WEAK
  GOOD
  VERY_GOOD
  EXCELLENT
}

enum JobHardFilterStatus {
  PASS
  FAIL
  WARN
}

/// Hiring-side profile for the Job Matching Engine v3.
/// Represents a job posting or hiring need.
model HiringProfile {
  id                      String            @id @default(uuid())
  userId                  String            @map("user_id")
  organizationId          String?           @map("organization_id")
  fullName                String?           @map("full_name") @db.VarChar(200)
  title                   String            @db.VarChar(200)
  roleArea                String            @map("role_area") @db.VarChar(255)
  seniority               JobSeniority
  location                String            @db.VarChar(255)
  workMode                JobWorkMode       @map("work_mode")
  employmentType          JobEmploymentType @map("employment_type")
  mustHaveSkills          Json              @map("must_have_skills")
  preferredSkills         Json?             @map("preferred_skills")
  jobSummaryRequirements  String            @map("job_summary_requirements") @db.Text
  minimumYearsExperience  Int?              @map("minimum_years_experience")
  hiringUrgency           JobHiringUrgency? @map("hiring_urgency")
  industries              Json?
  requiredLanguages       Json?             @map("required_languages")
  requiredCertifications  Json?             @map("required_certifications")
  requiredEducationLevels Json?             @map("required_education_levels")
  salaryRange             Json?             @map("salary_range")
  tags                    Json              @default("[]")
  embedding               Json?
  dataQualityScore        Int               @default(50) @map("data_quality_score")
  excludedCandidates      Json              @default("[]") @map("excluded_candidates")
  isActive                Boolean           @default(true) @map("is_active")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  user         User          @relation("UserHiringProfiles", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id])
  jobMatches   JobMatch[]

  @@index([userId])
  @@index([organizationId])
  @@index([seniority])
  @@index([isActive])
  @@map("hiring_profiles")
}

/// Candidate-side profile for the Job Matching Engine v3.
/// Represents a person open to opportunities.
model CandidateProfile {
  id                        String           @id @default(uuid())
  userId                    String           @map("user_id")
  organizationId            String?          @map("organization_id")
  fullName                  String?          @map("full_name") @db.VarChar(200)
  title                     String           @db.VarChar(200)
  roleArea                  String           @map("role_area") @db.VarChar(255)
  seniority                 JobSeniority
  location                  String           @db.VarChar(255)
  desiredWorkMode           Json             @map("desired_work_mode")
  desiredEmploymentType     Json             @map("desired_employment_type")
  skills                    Json
  profileSummaryPreferences String           @map("profile_summary_preferences") @db.Text
  yearsOfExperience         Int?             @map("years_of_experience")
  availability              JobAvailability?
  languages                 Json?
  certifications            Json?
  industries                Json?
  education                 Json?
  expectedSalary            Json?            @map("expected_salary")
  noticePeriod              Int?             @map("notice_period")
  relevantExperience        Json?            @map("relevant_experience")
  tags                      Json             @default("[]")
  embedding                 Json?
  dataQualityScore          Int              @default(50) @map("data_quality_score")
  optedOut                  Boolean          @default(false) @map("opted_out")
  blocked                   Boolean          @default(false)
  isActive                  Boolean          @default(true) @map("is_active")
  createdAt                 DateTime         @default(now()) @map("created_at")
  updatedAt                 DateTime         @updatedAt @map("updated_at")

  user         User          @relation("UserCandidateProfiles", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id])
  jobMatches   JobMatch[]

  @@index([userId])
  @@index([organizationId])
  @@index([seniority])
  @@index([optedOut, blocked])
  @@index([dataQualityScore(sort: Desc)])
  @@index([isActive])
  @@map("candidate_profiles")
}

/// Match result from the Job Matching Engine v3.
model JobMatch {
  id                 String              @id @default(uuid())
  jobId              String              @map("job_id")
  candidateId        String              @map("candidate_id")
  deterministicScore Float               @map("deterministic_score")
  aiScore            Float?              @map("ai_score")
  finalScore         Float               @map("final_score")
  confidence         Float
  matchLevel         JobMatchLevel       @map("match_level")
  hardFilterStatus   JobHardFilterStatus @map("hard_filter_status")
  hardFilterReason   String?             @map("hard_filter_reason") @db.VarChar(100)
  scoreBreakdown     Json                @map("score_breakdown")
  explanation        Json?
  keyReasons         Json                @map("key_reasons")
  rank               Int
  version            Int                 @default(1)
  archived           Boolean             @default(false)
  archivedAt         DateTime?           @map("archived_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  expiresAt          DateTime            @map("expires_at")

  hiringProfile    HiringProfile    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateProfile CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([jobId, archived])
  @@index([candidateId])
  @@index([finalScore(sort: Desc)])
  @@index([rank])
  @@map("job_matches")
}
