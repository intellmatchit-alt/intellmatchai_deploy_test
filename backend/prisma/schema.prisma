  @@unique([dealRequestId, contactId])
  @@index([dealRequestId])
  @@index([contactId])
  @@index([dealRequestId, score])
  @@map("deal_match_results")
}

/// Deal Job model for async processing
model DealJob {
  id            String        @id @default(uuid())
  dealRequestId String        @map("deal_request_id")
  step          DealJobStep
  status        DealJobStatus @default(PENDING)
  progress      Int           @default(0) @db.SmallInt
  error         String?       @db.Text
  attempts      Int           @default(0) @db.SmallInt
  maxAttempts   Int           @default(3) @map("max_attempts") @db.SmallInt
  startedAt     DateTime?     @map("started_at")
  completedAt   DateTime?     @map("completed_at")
  bullJobId     String?       @map("bull_job_id") @db.VarChar(100)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  dealRequest   DealRequest   @relation(fields: [dealRequestId], references: [id], onDelete: Cascade)

  @@unique([dealRequestId, step])
  @@index([dealRequestId])
  @@index([status])
  @@map("deal_jobs")
}

model ProductProfile {
  id                String      @id @default(uuid())
  userId            String      @unique @map("user_id")
  productType       ProductType @map("product_type")
  productName       String?     @map("product_name") @db.VarChar(255)
  targetIndustry    String      @map("target_industry") @db.VarChar(255)
  targetCompanySize String      @map("target_company_size") @db.VarChar(100)
  problemSolved     String      @map("problem_solved") @db.Text
  decisionMakerRole String      @map("decision_maker_role") @db.VarChar(255)
  additionalContext String?     @map("additional_context") @db.Text
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchRuns         ProductMatchRun[]

  @@index([userId])
  @@map("product_profiles")
}

model ProductMatchRun {
  id               String                @id @default(uuid())
  userId           String                @map("user_id")
  productProfileId String                @map("product_profile_id")
  status           ProductMatchRunStatus @default(QUEUED)
  progress         Int                   @default(0) @db.SmallInt
  totalContacts    Int                   @default(0) @map("total_contacts")
  matchCount       Int                   @default(0) @map("match_count")
  avgScore         Int                   @default(0) @map("avg_score")
  error            String?               @db.Text
  startedAt        DateTime?             @map("started_at")
  completedAt      DateTime?             @map("completed_at")
  bullJobId        String?               @map("bull_job_id") @db.VarChar(100)
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  productProfile   ProductProfile        @relation(fields: [productProfileId], references: [id], onDelete: Cascade)
  results          ProductMatchResult[]

  @@index([userId])
  @@index([productProfileId])
  @@index([status])
  @@index([userId, createdAt(sort: Desc)])
  @@map("product_match_runs")
}

model ProductMatchResult {
  id              String            @id @default(uuid())
  matchRunId      String            @map("match_run_id")
  contactId       String            @map("contact_id")
  score           Int               @db.SmallInt
  badge           ProductMatchBadge
  explanationJson Json              @map("explanation_json")
  talkAngle       String?           @map("talk_angle") @db.Text
  openerMessage   String?           @map("opener_message") @db.Text
  openerEdited    String?           @map("opener_edited") @db.Text
  breakdownJson   Json              @map("breakdown_json")
  isSaved         Boolean           @default(false) @map("is_saved")
  isDismissed     Boolean           @default(false) @map("is_dismissed")
  isContacted     Boolean           @default(false) @map("is_contacted")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  matchRun        ProductMatchRun   @relation(fields: [matchRunId], references: [id], onDelete: Cascade)
  contact         Contact           @relation(fields: [contactId], references: [id])

  @@unique([matchRunId, contactId])
  @@index([matchRunId])
  @@index([contactId])
  @@index([matchRunId, score(sort: Desc)])
  @@map("product_match_results")
}

/// Request from owner to collaborator (polymorphic - links to feature)
/// Can be sent to either a User (toUserId) or a Contact (toContactId)
model CollaborationRequest {
  id              String                     @id @default(uuid())
  fromUserId      String                     @map("from_user_id")
  toUserId        String?                    @map("to_user_id")
  message         String?                    @db.Text
  voiceMessageUrl String?                    @map("voice_message_url") @db.VarChar(500)
  status          CollaborationRequestStatus @default(PENDING)
  respondedAt     DateTime?                  @map("responded_at")
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")
  dealId          String?                    @map("deal_id")
  opportunityId   String?                    @map("opportunity_id")
  pitchId         String?                    @map("pitch_id")
  projectId       String?                    @map("project_id")
  sourceType      CollaborationSourceType    @map("source_type")
  toContactId     String?                    @map("to_contact_id")
  fromUser        User                       @relation("CollabRequestFromUser", fields: [fromUserId], references: [id])
  toUser          User?                      @relation("CollabRequestToUser", fields: [toUserId], references: [id])
  toContact       Contact?                   @relation(fields: [toContactId], references: [id])
  project         Project?                   @relation(fields: [projectId], references: [id])
  opportunity     OpportunityIntent?         @relation(fields: [opportunityId], references: [id])
  pitch           Pitch?                     @relation(fields: [pitchId], references: [id])
  deal            DealRequest?               @relation(fields: [dealId], references: [id])
  session         CollaborationSession?
  introductions   Introduction[]
  invitations     CollaborationInvitation[]

  @@unique([projectId, toUserId])
  @@unique([opportunityId, toUserId])
  @@unique([pitchId, toUserId])
  @@unique([dealId, toUserId])
  @@unique([projectId, toContactId])
  @@unique([opportunityId, toContactId])
  @@unique([pitchId, toContactId])
  @@unique([dealId, toContactId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([toContactId])
  @@index([status])
  @@index([sourceType])
  @@index([toUserId, status])
  @@map("collaboration_requests")
}

/// Matching session created when collaborator accepts
model CollaborationSession {
  id                     String    @id @default(uuid())
  collaborationRequestId String    @unique @map("collaboration_request_id")
  collaboratorUserId     String    @map("collaborator_user_id")
  contactsSource         String    @default("internal_contacts") @map("contacts_source")
  totalContacts          Int       @default(0) @map("total_contacts")
  matchCount             Int       @default(0) @map("match_count")
  progress               Int       @default(0) @db.SmallInt
  status                 String    @default("PENDING")
  bullJobId              String?   @map("bull_job_id") @db.VarChar(100)
  error                  String?   @db.Text
  startedAt              DateTime? @map("started_at")
  lastScanAt             DateTime? @map("last_scan_at")
  completedAt            DateTime? @map("completed_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  collaborationRequest   CollaborationRequest @relation(fields: [collaborationRequestId], references: [id])
  matchResults           CollaborationMatchResult[]

  @@index([collaboratorUserId])
  @@index([status])
  @@map("collaboration_sessions")
}

/// Match results visible ONLY to collaborator
model CollaborationMatchResult {
  id           String   @id @default(uuid())
  sessionId    String   @map("session_id")
  contactId    String   @map("contact_id")
  score        Int      @db.SmallInt
  reasonsJson  Json     @map("reasons_json")
  isIntroduced Boolean  @default(false) @map("is_introduced")
  isDismissed  Boolean  @default(false) @map("is_dismissed")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  session      CollaborationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contact      Contact              @relation(fields: [contactId], references: [id])
  invitations  CollaborationInvitation[]

  @@unique([sessionId, contactId])
  @@index([sessionId])
  @@index([sessionId, score(sort: Desc)])
  @@index([contactId], map: "collaboration_match_results_contact_id_fkey")
  @@map("collaboration_match_results")
}

/// Introduction tracking (contact ref hidden from owner)
model Introduction {
  id                     String             @id @default(uuid())
  collaborationRequestId String             @map("collaboration_request_id")
  collaboratorUserId     String             @map("collaborator_user_id")
  thirdPartyContactRef   String             @map("third_party_contact_ref")
  status                 IntroductionStatus @default(PENDING)
  completedAt            DateTime?          @map("completed_at")
  token                  String?            @unique
  channel                String?
  contactEmail           String?            @map("contact_email")
  contactPhone           String?            @map("contact_phone")
  contactName            String?            @map("contact_name")
  message                String?            @db.Text
  sentAt                 DateTime?          @map("sent_at")
  respondedAt            DateTime?          @map("responded_at")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  collaborationRequest   CollaborationRequest @relation(fields: [collaborationRequestId], references: [id])
  collaborator           User                 @relation("IntroductionCollaborator", fields: [collaboratorUserId], references: [id])

  @@index([collaborationRequestId])
  @@index([collaboratorUserId])
  @@index([status])
  @@map("introductions")
}

/// Permanent collaboration history
model CollaborationLedger {
  id                 String                  @id @default(uuid())
  fromUserId         String                  @map("from_user_id")
  toUserId           String                  @map("to_user_id")
  introductionsCount Int                     @default(0) @map("introductions_count")
  lastIntroductionAt DateTime?               @map("last_introduction_at")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  sourceId           String                  @map("source_id")
  sourceType         CollaborationSourceType @map("source_type")
  fromUser           User                    @relation("CollabLedgerFromUser", fields: [fromUserId], references: [id])
  toUser             User                    @relation("CollabLedgerToUser", fields: [toUserId], references: [id])

  @@unique([fromUserId, toUserId, sourceType, sourceId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([sourceType])
  @@map("collaboration_ledger")
}

/// User collaboration preferences
model CollaborationSettings {
  id                         String   @id @default(uuid())
  userId                     String   @unique @map("user_id")
  globalCollaborationEnabled Boolean  @default(true) @map("global_collaboration_enabled")
  blockedUserIdsJson         Json     @map("blocked_user_ids_json")
  allowedUserIdsJson         Json?    @map("allowed_user_ids_json")
  perTypeOverridesJson       Json?    @map("per_type_overrides_json")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")
  allowedSourceTypesJson     Json     @map("allowed_source_types_json")
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("collaboration_settings")
}

/// Invitation sent to third party (matched contact) via WhatsApp/Email
model CollaborationInvitation {
  id                     String            @id @default(uuid())
  collaborationRequestId String            @map("collaboration_request_id")
  matchResultId          String?           @map("match_result_id")
  recipientName          String            @map("recipient_name") @db.VarChar(255)
  recipientEmail         String?           @map("recipient_email") @db.VarChar(255)
  recipientPhone         String?           @map("recipient_phone") @db.VarChar(50)
  channel                InvitationChannel @default(EMAIL)
  token                  String            @unique @db.VarChar(100)
  message                String?           @db.Text
  sentAt                 DateTime?         @map("sent_at")
  deliveredAt            DateTime?         @map("delivered_at")
  openedAt               DateTime?         @map("opened_at")
  respondedAt            DateTime?         @map("responded_at")
  status                 TeamMemberStatus  @default(INVITED)
  declineReason          String?           @map("decline_reason") @db.Text
  teamMemberId           String?           @map("team_member_id")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  collaborationRequest   CollaborationRequest     @relation(fields: [collaborationRequestId], references: [id])
  matchResult            CollaborationMatchResult? @relation(fields: [matchResultId], references: [id])

  @@index([collaborationRequestId])
  @@index([token])
  @@index([status])
  @@index([recipientEmail])
  @@index([matchResultId], map: "collaboration_invitations_match_result_id_fkey")
  @@map("collaboration_invitations")
}

/// Project team member - someone who joined a project
model ProjectMember {
  id              String           @id @default(uuid())
  projectId       String           @map("project_id")
  userId          String?          @map("user_id")
  externalName    String?          @map("external_name") @db.VarChar(255)
  externalEmail   String?          @map("external_email") @db.VarChar(255)
  externalPhone   String?          @map("external_phone") @db.VarChar(50)
  role            TeamMemberRole   @default(MEMBER)
  status          TeamMemberStatus @default(INVITED)
  invitationToken String?          @unique @map("invitation_token") @db.VarChar(100)
  invitedAt       DateTime         @default(now()) @map("invited_at")
  joinedAt        DateTime?        @map("joined_at")
  removedAt       DateTime?        @map("removed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User?            @relation("ProjectMemberUser", fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@unique([projectId, externalEmail])
  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@map("project_members")
}

/// Opportunity team member
model OpportunityMember {
  id              String           @id @default(uuid())
  opportunityId   String           @map("opportunity_id")
  userId          String?          @map("user_id")
  externalName    String?          @map("external_name") @db.VarChar(255)
