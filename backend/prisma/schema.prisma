enum AffiliateStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum AffiliateCodeStatus {
  ACTIVE
  PAUSED
  EXPIRED
}

enum AffiliatePayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AffiliateCommissionStatus {
  PENDING
  EARNED
  PAID
  CANCELLED
}

/// Affiliate profile — one per user
model Affiliate {
  id                  String           @id @default(uuid())
  userId              String           @unique @map("user_id")
  status              AffiliateStatus  @default(PENDING)
  acceptedTermsAt     DateTime?        @map("accepted_terms_at")
  termsVersion        String?          @map("terms_version") @db.VarChar(20)
  appliedAt           DateTime         @default(now()) @map("applied_at")
  approvedAt          DateTime?        @map("approved_at")
  suspendedAt         DateTime?        @map("suspended_at")
  suspendedReason     String?          @map("suspended_reason") @db.Text
  totalEarnings       Decimal          @default(0) @map("total_earnings") @db.Decimal(10, 2)
  totalEarningsPoints Int              @default(0) @map("total_earnings_points")
  payoutBalance       Decimal          @default(0) @map("payout_balance") @db.Decimal(10, 2)
  payoutBalancePoints Int              @default(0) @map("payout_balance_points")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  codes               AffiliateCode[]
  referrals           AffiliateReferral[]
  payouts             AffiliatePayout[]

  @@index([status])
  @@map("affiliates")
}

/// Affiliate referral/promo codes
model AffiliateCode {
  id              String              @id @default(uuid())
  affiliateId     String              @map("affiliate_id")
  name            String?             @db.VarChar(100)
  code            String              @unique @db.VarChar(50)
  discountPercent Decimal             @map("discount_percent") @db.Decimal(5, 2)
  status          AffiliateCodeStatus @default(ACTIVE)
  usageCount      Int                 @default(0) @map("usage_count")
  totalRevenue    Decimal             @default(0) @map("total_revenue") @db.Decimal(10, 2)
  totalCommission Decimal             @default(0) @map("total_commission") @db.Decimal(10, 2)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  affiliate       Affiliate           @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referrals       AffiliateReferral[]

  @@index([affiliateId])
  @@index([code])
  @@map("affiliate_codes")
}

/// Tracks each person referred by an affiliate code
model AffiliateReferral {
  id                String                    @id @default(uuid())
  affiliateId       String                    @map("affiliate_id")
  codeId            String                    @map("code_id")
  referredUserId    String?                   @map("referred_user_id")
  referredEmail     String                    @map("referred_email") @db.VarChar(255)
  registeredAt      DateTime?                 @map("registered_at")
  purchasedAt       DateTime?                 @map("purchased_at")
  purchaseAmount    Decimal?                  @map("purchase_amount") @db.Decimal(10, 2)
  discountAmount    Decimal?                  @map("discount_amount") @db.Decimal(10, 2)
  commissionPercent Decimal?                  @map("commission_percent") @db.Decimal(5, 2)
  commissionAmount  Decimal?                  @map("commission_amount") @db.Decimal(10, 2)
  commissionPoints  Int?                      @map("commission_points")
  commissionStatus  AffiliateCommissionStatus @default(PENDING)
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  affiliate         Affiliate                 @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  code              AffiliateCode             @relation(fields: [codeId], references: [id], onDelete: Cascade)
  referredUser      User?                     @relation("ReferredByAffiliate", fields: [referredUserId], references: [id], onDelete: SetNull)

  @@index([affiliateId])
  @@index([codeId])
  @@index([referredUserId])
  @@index([referredEmail])
  @@map("affiliate_referrals")
}

/// Affiliate withdrawal/payout records
model AffiliatePayout {
  id            String                @id @default(uuid())
  affiliateId   String                @map("affiliate_id")
  amount        Decimal               @db.Decimal(10, 2)
  points        Int                   @default(0)
  paymentMode   String                @map("payment_mode") @db.VarChar(10)
  status        AffiliatePayoutStatus @default(PENDING)
  processedAt   DateTime?             @map("processed_at")
  notes         String?               @db.Text
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  affiliate     Affiliate             @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([status])
  @@map("affiliate_payouts")
}

enum BugReportUrgency {
  LOW
  MEDIUM
  HIGH
}

/// Bug report categories
enum BugReportCategory {
  BUG
  UI_ISSUE
  PERFORMANCE
  FEATURE_REQUEST
  OTHER
}

/// Bug report status
enum BugReportStatus {
  OPEN
  IN_PROGRESS
  DONE
  WONT_FIX
}

/// User-submitted QA/Bug reports
model BugReport {
  id            String              @id @default(uuid())
  userId        String              @map("user_id")
  description   String              @db.Text
  urgency       BugReportUrgency    @default(MEDIUM)
  category      BugReportCategory   @default(BUG)
  status        BugReportStatus     @default(OPEN)
  pagePath      String              @map("page_path") @db.VarChar(500)
  pageTitle     String?             @map("page_title") @db.VarChar(255)
  screenshotUrl String?             @map("screenshot_url") @db.Text
  userAgent     String?             @map("user_agent") @db.VarChar(500)
  appVersion    String?             @map("app_version") @db.VarChar(50)
  platform      String?             @db.VarChar(500)
  adminNotes    String?             @map("admin_notes") @db.Text
  resolvedAt    DateTime?           @map("resolved_at")
  resolvedById  String?             @map("resolved_by_id")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@index([urgency])
  @@index([category])
  @@map("bug_reports")
}

