# ===========================================
# P2P NETWORK - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values
# See docs/setup/THIRD_PARTY_SERVICES.md for detailed setup guides

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development

# ===========================================
# SWAGGER API DOCUMENTATION
# ===========================================
SWAGGER_ENABLED=true
SWAGGER_USER=intellmatch
SWAGGER_PASSWORD=intellmatch@docs2024
PORT=3001
APP_NAME=P2P Network
APP_URL=http://localhost:3001

# ===========================================
# DATABASE (MySQL) - REQUIRED
# ===========================================
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root@127.0.0.1:3306/p2p_network"

# ===========================================
# REDIS (Optional - for caching)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# NEO4J (Optional - for graph visualization)
# ===========================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# ===========================================
# JWT AUTHENTICATION - REQUIRED
# ===========================================
# Generate secure keys: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_64_to_generate
JWT_REFRESH_SECRET=CHANGE_ME_use_openssl_rand_base64_64_to_generate
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===========================================
# FILE STORAGE (MinIO/S3)
# ===========================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=p2p-uploads
S3_REGION=us-east-1

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=http://localhost:3000

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=debug

# ===========================================
# AI SERVICES - AZURE DOCUMENT INTELLIGENCE
# ===========================================
# Purpose: High-accuracy OCR for business cards
# Get keys: Azure Portal > Document Intelligence > Keys and Endpoint
# Free tier: 500 pages/month
# Docs: https://azure.microsoft.com/en-us/products/ai-services/ai-document-intelligence
AZURE_DOCUMENT_ENDPOINT=
AZURE_DOCUMENT_KEY=

# ===========================================
# AI SERVICES - PEOPLE DATA LABS (PDL)
# ===========================================
# Purpose: Contact enrichment (employment, education, social profiles)
# Get keys: https://dashboard.peopledatalabs.com/api-keys
# Free tier: 100 credits
# Docs: https://docs.peopledatalabs.com
PDL_API_KEY=

# ===========================================
# AI SERVICES - RECOMBEE
# ===========================================
# Purpose: ML-powered personalized recommendations
# Get keys: https://admin.recombee.com > Your Database > Settings
# Free tier: 100K requests/month
# Docs: https://docs.recombee.com
RECOMBEE_DATABASE_ID=
RECOMBEE_SECRET_TOKEN=

# ===========================================
# AI SERVICES - COHERE
# ===========================================
# Purpose: Semantic reranking for better search relevance
# Get keys: https://dashboard.cohere.com/api-keys
# Free tier: 1K requests
# Docs: https://docs.cohere.com/reference/rerank
COHERE_API_KEY=

# ===========================================
# LLM PROVIDERS (Choose One or More)
# ===========================================
# The system supports multiple LLM providers.
# Enable the ones you want to use and add API keys.
# Set AI_PROVIDER to choose which one to use:
#   - 'auto': Automatically pick the first enabled provider (recommended)
#   - 'groq': Force use Groq
#   - 'gemini': Force use Gemini
#   - 'openai': Force use OpenAI
#
# Priority order for 'auto': Groq > Gemini > OpenAI (free providers first)

AI_PROVIDER=auto

# -------------------------------------------
# GROQ (FREE - RECOMMENDED)
# -------------------------------------------
# Purpose: Fast LLM inference with Llama models
# Get keys: https://console.groq.com
# Free tier: Very generous (thousands of requests/day)
# Models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
FEATURE_GROQ=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# -------------------------------------------
# GOOGLE GEMINI (FREE)
# -------------------------------------------
# Purpose: Google's multimodal AI model
# Get keys: https://aistudio.google.com/apikey
# Free tier: 60 requests/minute, 1500 requests/day
# Models: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-exp
FEATURE_GEMINI=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# -------------------------------------------
# OPENAI (PAID)
# -------------------------------------------
# Purpose: AI-generated match explanations and messages
# Get keys: https://platform.openai.com/api-keys
# Free tier: $5 credit for new accounts (expires in 3 months)
# Models: gpt-4o-mini (cheapest), gpt-4o, gpt-3.5-turbo
FEATURE_OPENAI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===========================================
# OTHER FEATURE FLAGS
# ===========================================
# Set to 'true' to enable cloud AI services
# Set to 'false' to use free local fallbacks
#
# Local fallbacks:
# - OCR: Tesseract.js (free, 70-85% accuracy)
# - Enrichment: Manual entry only
# - Recommendations: Content-based filtering
# - Reranking: Keyword matching
# - Explanations: Template-based messages (if no LLM configured)

FEATURE_AZURE_OCR=false
FEATURE_PDL_ENRICHMENT=false
FEATURE_RECOMBEE=false
FEATURE_COHERE_RERANK=false
FEATURE_OPENAI_EXPLANATIONS=false
