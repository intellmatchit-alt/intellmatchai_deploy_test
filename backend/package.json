{
  "name": "p2p-backend",
  "version": "1.0.0",
  "description": "P2P Relationship Intelligence App - Backend API",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && cp src/config/swagger.yaml dist/config/",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --config jest.e2e.config.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed:match-test": "tsx prisma/seed-match-test.ts",
    "seed:match-test2": "tsx prisma/seed-match-test2.ts",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset",
    "docker:up": "docker-compose -f ../docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f ../docker/docker-compose.yml down",
    "docker:logs": "docker-compose -f ../docker/docker-compose.yml logs -f"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.25.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.0.0",
    "ical-generator": "^10.0.0",
    "inversify": "^6.0.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "libphonenumber-js": "^1.12.34",
    "mammoth": "^1.11.0",
    "minio": "^8.0.6",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "neo4j-driver": "^5.26.0",
    "nodemailer": "^7.0.12",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "^1.1.4",
    "pdfjs-dist": "^4.0.379",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^10.0.1",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.0",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^5.1.1",
    "tsyringe": "^4.10.0",
    "twilio": "^5.12.1",
    "uuid": "^11.0.3",
    "web-push": "^3.6.7",
    "winston": "^3.17.0",
    "yamljs": "^0.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.19.17",
    "@types/nodemailer": "^7.0.4",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.1",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@azure/ai-form-recognizer": "^5.0.0",
    "cohere-ai": "^7.14.0",
    "openai": "^4.73.0",
    "peopledatalabs": "^6.0.0",
    "recombee-api-client": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "author": "P2P Team",
  "license": "UNLICENSED",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
