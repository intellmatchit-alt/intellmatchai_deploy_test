# P2P Network - Production Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Database - MySQL
# ===========================================
MYSQL_ROOT_PASSWORD=your_strong_root_password_here
MYSQL_DATABASE=p2p_network
MYSQL_USER=p2p_user
MYSQL_PASSWORD=your_strong_mysql_password_here

# ===========================================
# Redis Cache
# ===========================================
REDIS_PASSWORD=your_strong_redis_password_here

# ===========================================
# Neo4j Graph Database
# ===========================================
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_strong_neo4j_password_here

# ===========================================
# MinIO (S3-compatible storage)
# ===========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_strong_minio_password_here

# ===========================================
# JWT Secrets (generate with: openssl rand -base64 64)
# ===========================================
JWT_SECRET=your_jwt_secret_here_generate_with_openssl
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_generate_with_openssl

# ===========================================
# Application URLs (replace with your domain)
# ===========================================
API_URL=https://yourdomain.com/api
WS_URL=wss://yourdomain.com/ws

# ===========================================
# Optional: AI Services (from your .env)
# ===========================================
# Groq (Free LLM)
GROQ_API_KEY=
FEATURE_GROQ=true

# OpenAI (Optional)
OPENAI_API_KEY=
FEATURE_OPENAI=false

# Gemini (Optional)
GEMINI_API_KEY=
FEATURE_GEMINI=false

# Azure Document Intelligence (OCR)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# People Data Labs (Contact enrichment)
PDL_API_KEY=

# Recombee (Recommendations)
RECOMBEE_DATABASE_ID=
RECOMBEE_PRIVATE_TOKEN=

# Cohere (Embeddings)
COHERE_API_KEY=
